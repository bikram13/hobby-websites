<header class="fixed top-0 w-full z-50 bg-zinc-900/60 backdrop-blur-xl border-b border-white/15">
<nav class="flex items-center justify-between px-8 py-4 max-w-screen-2xl mx-auto font-['Inter'] tracking-tight leading-relaxed">
<a href="/" class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-purple-400 hover:opacity-80 transition-opacity">Everyday Tools</a>
<div class="hidden md:flex items-center gap-8">
<a class="text-zinc-400 hover:text-white transition-colors duration-300 active:scale-95 transition-transform" href="/finance/">Finance</a>
<a class="text-zinc-400 hover:text-white transition-colors duration-300 active:scale-95 transition-transform" href="/health/">Health</a>
<a class="text-zinc-400 hover:text-white transition-colors duration-300 active:scale-95 transition-transform" href="/unit-converters/">Converters</a>
<a class="text-zinc-400 hover:text-white transition-colors duration-300 active:scale-95 transition-transform" href="/utility/">Utility</a>
<a class="text-zinc-400 hover:text-white transition-colors duration-300 active:scale-95 transition-transform" href="/about/">About</a>
</div>
<button id="hamburger-btn" class="md:hidden flex flex-col justify-center items-center w-8 h-8 gap-1.5 focus:outline-none" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu">
  <span class="hamburger-line block w-6 h-0.5 bg-zinc-300 transition-all duration-300 origin-center"></span>
  <span class="hamburger-line block w-6 h-0.5 bg-zinc-300 transition-all duration-300 origin-center"></span>
  <span class="hamburger-line block w-6 h-0.5 bg-zinc-300 transition-all duration-300 origin-center"></span>
</button>
</nav>
<div id="mobile-menu" class="md:hidden hidden flex-col px-8 pb-6 pt-2 gap-4 bg-zinc-900/95 border-t border-white/10">
<a class="text-zinc-300 hover:text-white py-2 transition-colors duration-200 border-b border-white/10 last:border-0" href="/finance/">Finance</a>
<a class="text-zinc-300 hover:text-white py-2 transition-colors duration-200 border-b border-white/10 last:border-0" href="/health/">Health</a>
<a class="text-zinc-300 hover:text-white py-2 transition-colors duration-200 border-b border-white/10 last:border-0" href="/unit-converters/">Converters</a>
<a class="text-zinc-300 hover:text-white py-2 transition-colors duration-200 border-b border-white/10 last:border-0" href="/utility/">Utility</a>
<a class="text-zinc-300 hover:text-white py-2 transition-colors duration-200" href="/about/">About</a>
</div>
</header>
<script>
(function() {
  var btn = document.getElementById('hamburger-btn');
  var menu = document.getElementById('mobile-menu');
  if (!btn || !menu) return;
  btn.addEventListener('click', function() {
    var isOpen = !menu.classList.contains('hidden');
    if (isOpen) {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      btn.setAttribute('aria-expanded', 'false');
    } else {
      menu.classList.remove('hidden');
      menu.classList.add('flex');
      btn.setAttribute('aria-expanded', 'true');
    }
  });
  // Close menu when a link is clicked
  menu.querySelectorAll('a').forEach(function(link) {
    link.addEventListener('click', function() {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      btn.setAttribute('aria-expanded', 'false');
    });
  });
})();
</script>
