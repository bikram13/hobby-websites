  theme: {
    extend: {
      colors: {
        "on-primary-fixed-variant": "#1f3ba6",
        "surface-dim": "#131315",
        "on-secondary-fixed-variant": "#5c3187",
        "inverse-primary": "#3c55bf",
        "surface-tint": "#b9c3ff",
        "background": "#131315",
        "on-error": "#690005",
        "on-secondary": "#44176f",
        "surface-container-high": "#2a2a2c",
        "secondary": "#dcb8ff",
        "tertiary-container": "#00a572",
        "on-tertiary-container": "#00311f",
        "secondary-fixed-dim": "#dcb8ff",
        "inverse-surface": "#e4e2e4",
        "outline": "#8f909e",
        "surface-variant": "#353437",
        "primary-fixed": "#dde1ff",
        "surface-bright": "#39393b",
        "on-error-container": "#ffdad6",
        "on-tertiary-fixed-variant": "#005236",
        "secondary-fixed": "#f0dbff",
        "outline-variant": "#444653",
        "on-secondary-container": "#d0a1ff",
        "on-primary": "#002388",
        "on-tertiary": "#003824",
        "tertiary": "#4edea3",
        "error-container": "#93000a",
        "tertiary-fixed": "#6ffbbe",
        "on-surface-variant": "#c5c5d5",
        "on-tertiary-fixed": "#002113",
        "on-surface": "#e4e2e4",
        "surface": "#131315",
        "surface-container-lowest": "#0e0e10",
        "surface-container": "#1f1f21",
        "tertiary-fixed-dim": "#4edea3",
        "inverse-on-surface": "#303032",
        "primary-container": "#7189f6",
        "surface-container-highest": "#353437",
        "on-background": "#e4e2e4",
        "on-primary-container": "#001e78",
        "secondary-container": "#5c3187",
        "primary": "#b9c3ff",
        "error": "#ffb4ab",
        "on-primary-fixed": "#001356",
        "on-secondary-fixed": "#2c0051",
        "surface-container-low": "#1b1b1d",
        "primary-fixed-dim": "#b9c3ff"
      },
      borderRadius: {
        "DEFAULT": "0.25rem",
