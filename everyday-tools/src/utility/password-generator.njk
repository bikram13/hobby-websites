<script>
(function () {
  'use strict';

  var UPPER   = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  var LOWER   = 'abcdefghijklmnopqrstuvwxyz';
  var NUMS    = '0123456789';
  var SYMS    = '!@#$%^&*()_+-=[]{}|;:,.<>?';

  function cryptoRandBelow(n) {
    // rejection sampling — no modulo bias
    var max = Math.floor(0x100000000 / n) * n;
    var buf = new Uint32Array(1);
    do { crypto.getRandomValues(buf); } while (buf[0] >= max);
    return buf[0] % n;
  }

  function buildCharset() {
    var s = '';
    if (document.getElementById('pg-uppercase').checked) s += UPPER;
    if (document.getElementById('pg-lowercase').checked) s += LOWER;
    if (document.getElementById('pg-numbers').checked)   s += NUMS;
    if (document.getElementById('pg-symbols').checked)   s += SYMS;
    return s;
  }

  function generatePassword(len, charset) {
    if (!charset) return '';
    var out = '';
    for (var i = 0; i < len; i++) out += charset[cryptoRandBelow(charset.length)];
    return out;
  }

  function calcEntropy(len, charsetSize) {
    if (!charsetSize) return 0;
    return Math.floor(len * Math.log2(charsetSize));
  }

  var STRENGTH_LEVELS = [
    { label: 'Very Weak',  pct: 10, color: '#ef4444' },
    { label: 'Weak',       pct: 30, color: '#f97316' },
    { label: 'Fair',       pct: 50, color: '#eab308' },
    { label: 'Strong',     pct: 70, color: '#22c55e' },
    { label: 'Very Strong',pct: 88, color: '#06b6d4' },
    { label: 'Exceptional',pct: 100, color: null }     // null = gradient
  ];

  function strengthFromEntropy(bits) {
    if (bits < 28)  return STRENGTH_LEVELS[0];
    if (bits < 40)  return STRENGTH_LEVELS[1];
    if (bits < 60)  return STRENGTH_LEVELS[2];
    if (bits < 80)  return STRENGTH_LEVELS[3];
    if (bits < 110) return STRENGTH_LEVELS[4];
    return STRENGTH_LEVELS[5];
  }

  function updateUI() {
    var len     = parseInt(document.getElementById('pg-length-slider').value, 10);
    var charset = buildCharset();
    var pwd     = generatePassword(len, charset);
    var bits    = calcEntropy(len, charset.length);
    var level   = strengthFromEntropy(bits);

    document.getElementById('pg-output').textContent       = pwd || '— select at least one charset —';
    document.getElementById('pg-length-display').textContent = len;
    document.getElementById('pg-strength-label').textContent = level.label;
    document.getElementById('pg-entropy-label').textContent  = 'Entropy: ' + bits + '-bit';

    var bar = document.getElementById('pg-strength-bar');
    bar.style.width = level.pct + '%';
    if (level.color) {
      bar.style.background = level.color;
    } else {
      bar.style.background = '';
      bar.classList.add('bg-gradient-to-r', 'from-primary', 'to-tertiary');
    }

    document.getElementById('pg-copy-label').textContent = 'Copy';
  }

  // Slider live update
  document.getElementById('pg-length-slider').addEventListener('input', function () {
    document.getElementById('pg-length-display').textContent = this.value;
    updateUI();
  });

  // Checkbox changes
  ['pg-uppercase','pg-lowercase','pg-numbers','pg-symbols'].forEach(function (id) {
    document.getElementById(id).addEventListener('change', updateUI);
  });

  // Regenerate button
  document.getElementById('pg-regen-btn').addEventListener('click', updateUI);

  // Copy button
  document.getElementById('pg-copy-btn').addEventListener('click', function () {
    var pwd = document.getElementById('pg-output').textContent.trim();
    if (!pwd || pwd.includes('—')) return;
    navigator.clipboard.writeText(pwd).then(function () {
      document.getElementById('pg-copy-label').textContent = 'Copied!';
      setTimeout(function () {
        document.getElementById('pg-copy-label').textContent = 'Copy';
      }, 2000);
    });
  });

  // Initial render
  updateUI();
})();
</script>