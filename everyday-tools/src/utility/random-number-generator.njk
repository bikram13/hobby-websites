<script>
(function() {
  var minInput = document.getElementById('rng-min');
  var maxInput = document.getElementById('rng-max');
  var generateBtn = document.getElementById('rng-generate');
  var resultEl = document.getElementById('rng-result');
  var copyBtn = document.getElementById('rng-copy');
  var historyEl = document.getElementById('rng-history');
  var history = [];

  function generate() {
    var min = parseInt(minInput.value, 10);
    var max = parseInt(maxInput.value, 10);
    if (isNaN(min) || isNaN(max)) return;
    if (min > max) {
      var tmp = min; min = max; max = tmp;
      minInput.value = min;
      maxInput.value = max;
    }
    var result = Math.floor(Math.random() * (max - min + 1)) + min;
    resultEl.textContent = result;
    history.unshift(result);
    if (history.length > 6) history = history.slice(0, 6);
    renderHistory();
  }

  function renderHistory() {
    historyEl.innerHTML = '';
    history.forEach(function(num, idx) {
      var span = document.createElement('span');
      span.className = 'bg-white/5 px-3 py-1 rounded-full text-sm font-mono ' + (idx === 0 ? 'text-primary' : 'text-zinc-500');
      span.textContent = num;
      historyEl.appendChild(span);
    });
  }

  function copyToClipboard() {
    var val = resultEl.textContent;
    if (val === '--') return;
    if (navigator.clipboard) {
      navigator.clipboard.writeText(val);
    } else {
      var ta = document.createElement('textarea');
      ta.value = val;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }
    var origText = copyBtn.querySelector('span:last-child');
    origText.textContent = 'Copied!';
    setTimeout(function() { origText.textContent = 'Copy'; }, 1500);
  }

  generateBtn.addEventListener('click', generate);
  copyBtn.addEventListener('click', copyToClipboard);
})();
</script>