<script>
(function () {
  'use strict';

  function fmt(tz, opts) {
    return new Intl.DateTimeFormat('en-US', Object.assign({ timeZone: tz }, opts));
  }

  function timeStr(tz) {
    return fmt(tz, { hour: 'numeric', minute: '2-digit', second: '2-digit', hour12: true }).format(new Date());
  }

  function shortTimeStr(tz) {
    return fmt(tz, { hour: 'numeric', minute: '2-digit', hour12: true }).format(new Date());
  }

  function dateStr(tz) {
    return fmt(tz, { weekday: 'long', month: 'short', day: 'numeric' }).format(new Date());
  }

  function hourOf(tz) {
    return parseInt(fmt(tz, { hour: 'numeric', hour12: false }).format(new Date()), 10);
  }

  function timeLabel(tz) {
    var h = hourOf(tz);
    if (h >= 22 || h < 5)  return 'Night Owl';
    if (h >= 5  && h < 9)  return 'Early Bird';
    if (h >= 9  && h < 12) return 'Morning';
    if (h >= 12 && h < 14) return 'Midday';
    if (h >= 14 && h < 18) return 'Afternoon';
    if (h >= 18 && h < 21) return 'Evening';
    return 'Late Night';
  }

  function offsetStr(tz) {
    // e.g. "PDT (GMT-7)"
    var parts = new Intl.DateTimeFormat('en-US', {
      timeZone: tz,
      timeZoneName: 'short'
    }).formatToParts(new Date());
    var abbr = (parts.find(function (p) { return p.type === 'timeZoneName'; }) || {}).value || '';
    var offsetMs = -new Date().getTimezoneOffset() * 60000;
    var now = new Date();
    var localOff = now.getTimezoneOffset();
    // Get actual UTC offset for the tz via formatting trick
    var utcDate = new Date(now.toLocaleString('en-US', { timeZone: 'UTC' }));
    var tzDate  = new Date(now.toLocaleString('en-US', { timeZone: tz }));
    var diffHrs = (tzDate - utcDate) / 3600000;
    var sign = diffHrs >= 0 ? '+' : '-';
    var absH = Math.floor(Math.abs(diffHrs));
    var absM = Math.round((Math.abs(diffHrs) - absH) * 60);
    var gmtPart = 'GMT' + sign + absH + (absM ? ':' + String(absM).padStart(2,'0') : '');
    return abbr + ' (' + gmtPart + ')';
  }

  // Update all clocks
  function tick() {
    // SF hero
    document.getElementById('tz-sf-time').textContent = timeStr('America/Los_Angeles');
    document.getElementById('tz-sf-date').textContent = dateStr('America/Los_Angeles');
    document.getElementById('tz-sf-offset').textContent = offsetStr('America/Los_Angeles');

    // Map tooltips
    document.getElementById('tz-map-sf').textContent     = 'SF ' + shortTimeStr('America/Los_Angeles');
    document.getElementById('tz-map-london').textContent = 'London ' + shortTimeStr('Europe/London');
    document.getElementById('tz-map-tokyo').textContent  = 'Tokyo ' + shortTimeStr('Asia/Tokyo');

    // Sidebar list items
    document.querySelectorAll('.tz-list-item').forEach(function (el) {
      var tz = el.dataset.tz;
      el.querySelector('.tz-time').textContent = shortTimeStr(tz);
      el.querySelector('.tz-abbr').textContent = offsetStr(tz);
    });

    // Comparison grid
    document.getElementById('tz-dubai').textContent        = shortTimeStr('Asia/Dubai');
    document.getElementById('tz-dubai-label').textContent  = timeLabel('Asia/Dubai');
    document.getElementById('tz-berlin').textContent       = shortTimeStr('Europe/Berlin');
    document.getElementById('tz-berlin-label').textContent = timeLabel('Europe/Berlin');
    document.getElementById('tz-sydney').textContent       = shortTimeStr('Australia/Sydney');
    document.getElementById('tz-sydney-label').textContent = timeLabel('Australia/Sydney');
    document.getElementById('tz-mumbai').textContent       = shortTimeStr('Asia/Kolkata');
    document.getElementById('tz-mumbai-label').textContent = timeLabel('Asia/Kolkata');
  }

  // Search / filter sidebar list
  document.getElementById('tz-search').addEventListener('input', function () {
    var q = this.value.toLowerCase().trim();
    document.querySelectorAll('.tz-list-item').forEach(function (el) {
      var label = (el.dataset.label || '').toLowerCase();
      var tz    = (el.dataset.tz   || '').toLowerCase();
      el.style.display = (!q || label.includes(q) || tz.includes(q)) ? '' : 'none';
    });
  });

  tick();
  setInterval(tick, 1000);
})();
</script>