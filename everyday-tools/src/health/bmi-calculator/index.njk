<script>
(function() {
  var unit = 'metric';

  window.setUnit = function(u) {
    unit = u;
    document.getElementById('btn-metric').classList.toggle('active', u === 'metric');
    document.getElementById('btn-imperial').classList.toggle('active', u === 'imperial');
    document.getElementById('metric-inputs').style.display = u === 'metric' ? '' : 'none';
    document.getElementById('imperial-inputs').style.display = u === 'imperial' ? '' : 'none';
    calculate();
  };

  window.calculate = function() {
    var bmi, heightM, weightKg;

    if (unit === 'metric') {
      var hcm = parseFloat(document.getElementById('height-cm').value);
      var wkg = parseFloat(document.getElementById('weight-kg').value);
      if (!hcm || !wkg || hcm <= 0 || wkg <= 0) { hide(); return; }
      heightM = hcm / 100;
      weightKg = wkg;
    } else {
      var hft = parseFloat(document.getElementById('height-ft').value) || 0;
      var hin = parseFloat(document.getElementById('height-in').value) || 0;
      var wlb = parseFloat(document.getElementById('weight-lb').value);
      if ((!hft && !hin) || !wlb || wlb <= 0) { hide(); return; }
      var totalIn = hft * 12 + hin;
      if (totalIn <= 0) { hide(); return; }
      heightM = totalIn * 0.0254;
      weightKg = wlb * 0.453592;
    }

    bmi = weightKg / (heightM * heightM);
    if (!isFinite(bmi) || bmi <= 0) { hide(); return; }

    var category, catClass;
    if (bmi < 18.5) { category = 'Underweight'; catClass = 'cat-underweight'; }
    else if (bmi < 25) { category = 'Normal weight'; catClass = 'cat-normal'; }
    else if (bmi < 30) { category = 'Overweight'; catClass = 'cat-overweight'; }
    else { category = 'Obese'; catClass = 'cat-obese'; }

    // Healthy weight range for this height
    var minKg = 18.5 * heightM * heightM;
    var maxKg = 24.9 * heightM * heightM;
    var rangeStr;
    if (unit === 'metric') {
      rangeStr = 'Healthy weight for your height: ' + minKg.toFixed(1) + ' kg &ndash; ' + maxKg.toFixed(1) + ' kg';
    } else {
      rangeStr = 'Healthy weight for your height: ' + (minKg / 0.453592).toFixed(1) + ' lb &ndash; ' + (maxKg / 0.453592).toFixed(1) + ' lb';
    }

    document.getElementById('bmi-value').textContent = bmi.toFixed(1);
    var catEl = document.getElementById('bmi-category');
    catEl.textContent = category;
    catEl.className = 'result-category ' + catClass;
    document.getElementById('healthy-range').innerHTML = rangeStr;

    // Position marker — scale from 0 to 40+, clamped
    var pct = Math.min(Math.max((bmi / 40) * 100, 2), 98);
    var marker = document.getElementById('scale-marker');
    marker.style.left = pct + '%';
    marker.style.display = 'block';

    document.getElementById('bmi-result').style.display = '';
  };

  function hide() {
    document.getElementById('bmi-result').style.display = 'none';
  }
})();
</script>
