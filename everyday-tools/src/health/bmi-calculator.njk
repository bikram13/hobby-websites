</main>

<script>
(function() {
  var isMetric = true;
  var metricBtn = document.getElementById('bmi-metric-btn');
  var imperialBtn = document.getElementById('bmi-imperial-btn');
  var weightInput = document.getElementById('bmi-weight');
  var heightInput = document.getElementById('bmi-height');
  var weightUnitEl = document.getElementById('bmi-weight-unit');
  var heightUnitEl = document.getElementById('bmi-height-unit');
  var calcBtn = document.getElementById('bmi-calculate');
  var bmiValueEl = document.getElementById('bmi-value');
  var bmiStatusEl = document.getElementById('bmi-status');
  var bmiMessageEl = document.getElementById('bmi-message');
  var gaugeCircle = document.getElementById('bmi-gauge-circle');
  var barUnder = document.getElementById('bmi-bar-under');
  var barHealthy = document.getElementById('bmi-bar-healthy');
  var barOver = document.getElementById('bmi-bar-over');
  var barObese = document.getElementById('bmi-bar-obese');

  var CIRCUMFERENCE = 552;

  function setUnit(metric) {
    isMetric = metric;
    if (metric) {
      metricBtn.className = 'px-6 py-2 rounded-full bg-primary-container text-on-primary-container font-bold text-sm transition-all';
      imperialBtn.className = 'px-6 py-2 rounded-full text-on-surface-variant font-medium text-sm hover:text-on-surface transition-all';
      weightUnitEl.textContent = 'kg';
      heightUnitEl.textContent = 'cm';
      weightInput.placeholder = '70';
      heightInput.placeholder = '175';
    } else {
      imperialBtn.className = 'px-6 py-2 rounded-full bg-primary-container text-on-primary-container font-bold text-sm transition-all';
      metricBtn.className = 'px-6 py-2 rounded-full text-on-surface-variant font-medium text-sm hover:text-on-surface transition-all';
      weightUnitEl.textContent = 'lbs';
      heightUnitEl.textContent = 'in';
      weightInput.placeholder = '154';
      heightInput.placeholder = '69';
    }
    weightInput.value = '';
    heightInput.value = '';
  }

  function getBmiCategory(bmi) {
    if (bmi < 18.5) return { status: 'Underweight', message: 'Your BMI is below the healthy range. Consider consulting a healthcare provider for guidance on healthy weight gain.', color: 'text-blue-400', bar: 'under' };
    if (bmi < 25)   return { status: 'Healthy Weight', message: 'You are within the recommended range. Maintaining a balanced diet and regular activity will sustain this health profile.', color: 'text-tertiary', bar: 'healthy' };
    if (bmi < 30)   return { status: 'Overweight', message: 'Your BMI is above the healthy range. A balanced diet and regular exercise can help you reach a healthier weight.', color: 'text-yellow-400', bar: 'over' };
    return { status: 'Obese', message: 'Your BMI is in the obese range. Consulting a healthcare provider for a personalised plan is recommended.', color: 'text-red-400', bar: 'obese' };
  }

  function updateGauge(bmi) {
    // Map BMI 10–40 range to dashoffset 552–0
    var clamped = Math.min(Math.max(bmi, 10), 40);
    var fraction = (clamped - 10) / 30;
    var offset = CIRCUMFERENCE - fraction * CIRCUMFERENCE;
    gaugeCircle.style.strokeDashoffset = offset;
  }

  function resetBars() {
    barUnder.className = 'h-1.5 rounded-full bg-blue-400/30';
    barHealthy.className = 'h-1.5 rounded-full bg-tertiary/30';
    barOver.className = 'h-1.5 rounded-full bg-yellow-400/30';
    barObese.className = 'h-1.5 rounded-full bg-red-400/30';
  }

  function calculate() {
    var weightVal = parseFloat(weightInput.value);
    var heightVal = parseFloat(heightInput.value);
    if (isNaN(weightVal) || isNaN(heightVal) || weightVal <= 0 || heightVal <= 0) {
      bmiValueEl.textContent = '--';
      bmiStatusEl.textContent = 'Enter your data';
      bmiMessageEl.textContent = 'Enter your weight and height above, then click Calculate Results to see your BMI.';
      gaugeCircle.style.strokeDashoffset = CIRCUMFERENCE;
      resetBars();
      return;
    }
    var bmi;
    if (isMetric) {
      var heightM = heightVal / 100;
      bmi = weightVal / (heightM * heightM);
    } else {
      bmi = (weightVal / (heightVal * heightVal)) * 703;
    }
    bmi = Math.round(bmi * 10) / 10;
    var cat = getBmiCategory(bmi);
    bmiValueEl.textContent = bmi.toFixed(1);
    bmiStatusEl.textContent = cat.status;
    bmiStatusEl.className = 'text-3xl font-black ' + cat.color;
    bmiMessageEl.textContent = '\u201c' + cat.message + '\u201d';
    updateGauge(bmi);
    resetBars();
    if (cat.bar === 'under')   barUnder.className = 'h-1.5 rounded-full bg-blue-400';
    if (cat.bar === 'healthy') barHealthy.className = 'h-1.5 rounded-full bg-tertiary';
    if (cat.bar === 'over')    barOver.className = 'h-1.5 rounded-full bg-yellow-400';
    if (cat.bar === 'obese')   barObese.className = 'h-1.5 rounded-full bg-red-400';
  }

  metricBtn.addEventListener('click', function() { setUnit(true); });
  imperialBtn.addEventListener('click', function() { setUnit(false); });
  calcBtn.addEventListener('click', calculate);
  weightInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') calculate(); });
  heightInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') calculate(); });
})();
</script>