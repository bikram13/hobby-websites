<div class="space-y-2">
<div class="flex justify-between items-end">
<label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Weight</label>
<span id="bmi-weight-unit" class="text-xs text-primary font-medium">kg</span>
</div>
<div class="relative group">
<input id="bmi-weight" class="w-full bg-surface-container-highest border-none rounded-xl py-4 px-6 text-2xl font-bold focus:ring-0 focus:outline-none placeholder:text-zinc-700" placeholder="70" type="number" min="1"/>
<div class="absolute bottom-0 left-0 w-0 h-[2px] bg-primary group-focus-within:w-full transition-all duration-500"></div>
</div>
</div>
<!-- Height Input -->
<div class="space-y-2">
<div class="flex justify-between items-end">
<label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Height</label>
<span id="bmi-height-unit" class="text-xs text-primary font-medium">cm</span>
</div>
<div class="relative group">
<input id="bmi-height" class="w-full bg-surface-container-highest border-none rounded-xl py-4 px-6 text-2xl font-bold focus:ring-0 focus:outline-none placeholder:text-zinc-700" placeholder="175" type="number" min="1"/>
<div class="absolute bottom-0 left-0 w-0 h-[2px] bg-primary group-focus-within:w-full transition-all duration-500"></div>
</div>
</div>
<button id="bmi-calculate" class="w-full py-5 rounded-xl bg-gradient-to-br from-primary-container to-secondary text-white font-bold text-lg shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all active:scale-[0.98]">
                        Calculate Results
                    </button>
</div>
</div>
<!-- Display Panel -->
<div class="lg:col-span-7 space-y-8">
<!-- BMI Gauge Card -->
<div class="glass-card rounded-xl p-8 relative overflow-hidden group">
<div class="absolute -top-24 -right-24 w-64 h-64 bg-tertiary/10 rounded-full blur-3xl group-hover:bg-tertiary/20 transition-all duration-700"></div>
<div class="relative z-10 flex flex-col md:flex-row items-center gap-12">
<div class="relative w-48 h-48 flex items-center justify-center">
<!-- Circular Gauge Placeholder -->
<svg class="w-full h-full -rotate-90">
<circle class="text-surface-container-highest" cx="96" cy="96" fill="transparent" r="88" stroke="currentColor" stroke-width="8"></circle>
<circle id="bmi-gauge-circle" class="text-tertiary" cx="96" cy="96" fill="transparent" r="88" stroke="currentColor" stroke-dasharray="552" stroke-dashoffset="552" stroke-linecap="round" stroke-width="10"></circle>
</svg>
<div class="absolute flex flex-col items-center">
<span id="bmi-value" class="text-4xl font-black tracking-tighter">--</span>
<span class="text-xs font-bold text-on-surface-variant uppercase tracking-widest">BMI Index</span>
</div>
</div>
<div class="flex-grow space-y-4">
<div>
<h3 class="text-tertiary text-sm font-bold uppercase tracking-[0.2em] mb-1">Status</h3>
<p id="bmi-status" class="text-3xl font-black text-on-surface">Enter your data</p>
</div>
<p id="bmi-message" class="text-on-surface-variant leading-relaxed text-sm italic">
