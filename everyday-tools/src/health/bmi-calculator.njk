<div id="bmi-bar-under" class="h-1.5 rounded-full bg-blue-400/30"></div>
<div id="bmi-bar-healthy" class="h-1.5 rounded-full bg-tertiary/30"></div>
<div id="bmi-bar-over" class="h-1.5 rounded-full bg-yellow-400/30"></div>
<div id="bmi-bar-obese" class="h-1.5 rounded-full bg-red-400/30"></div>
</div>
<div class="flex justify-between text-[10px] font-bold text-on-surface-variant uppercase tracking-wider">
<span>Under</span>
<span class="text-tertiary">Healthy</span>
<span>Over</span>
<span>Obese</span>
</div>
</div>
</div>
</div>
<!-- Bento Tips -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
<div class="glass-card rounded-xl p-6 border-l-4 border-tertiary">
<div class="flex items-center gap-3 mb-4">
<span class="material-symbols-outlined text-tertiary" data-icon="restaurant">restaurant</span>
<h4 class="font-bold tracking-tight">Nutritional Balance</h4>
</div>
<p class="text-sm text-on-surface-variant leading-relaxed">
                            Focus on whole foods and complex carbohydrates to maintain consistent energy levels throughout your tool-driven workflow.
                        </p>
</div>
<div class="glass-card rounded-xl p-6 border-l-4 border-primary">
<div class="flex items-center gap-3 mb-4">
<span class="material-symbols-outlined text-primary" data-icon="directions_run">directions_run</span>
<h4 class="font-bold tracking-tight">Activity Routine</h4>
</div>
<p class="text-sm text-on-surface-variant leading-relaxed">
                            Aim for at least 30 minutes of moderate activity daily to improve metabolic health and mental clarity.
                        </p>
</div>
</div>
</div>
</div>
<!-- Visual Anchor Section -->
<section class="mt-20">
