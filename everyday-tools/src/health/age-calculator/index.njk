<script>
(function() {
  // Set max date to today to prevent future dates
  var todayStr = new Date().toISOString().slice(0, 10);
  document.getElementById('dob').max = todayStr;

  window.calcAge = function() {
    var dobVal = document.getElementById('dob').value;
    var errorEl = document.getElementById('age-error');
    var resultEl = document.getElementById('age-result');

    if (!dobVal) {
      resultEl.style.display = 'none';
      errorEl.style.display = 'none';
      return;
    }

    var dob = new Date(dobVal + 'T00:00:00');
    var today = new Date();
    today.setHours(0, 0, 0, 0);

    if (dob >= today) {
      resultEl.style.display = 'none';
      errorEl.style.display = '';
      return;
    }
    errorEl.style.display = 'none';

    // Calculate years
    var years = today.getFullYear() - dob.getFullYear();
    var mDiff = today.getMonth() - dob.getMonth();
    var dDiff = today.getDate() - dob.getDate();

    if (dDiff < 0) { mDiff--; }
    if (mDiff < 0) { years--; mDiff += 12; }

    // Calculate months
    var months = mDiff;

    // Calculate days
    // Start from (dob + years + months), count remaining days
    var base = new Date(dob);
    base.setFullYear(base.getFullYear() + years);
    base.setMonth(base.getMonth() + months);
    var days = Math.floor((today - base) / (1000 * 60 * 60 * 24));

    // Total days lived
    var totalDays = Math.floor((today - dob) / (1000 * 60 * 60 * 24));

    // Next birthday
    var nextBday = new Date(today.getFullYear(), dob.getMonth(), dob.getDate());
    if (nextBday <= today) {
      nextBday.setFullYear(today.getFullYear() + 1);
    }
    var daysUntilBday = Math.floor((nextBday - today) / (1000 * 60 * 60 * 24));

    document.getElementById('age-years').textContent = years;
    document.getElementById('age-months').textContent = months;
    document.getElementById('age-days').textContent = days;
    document.getElementById('age-total-days').textContent = totalDays.toLocaleString() + ' days old in total';

    var bdayMsg;
    if (daysUntilBday === 0) {
      bdayMsg = '🎂 Happy Birthday! Your birthday is today.';
    } else if (daysUntilBday === 1) {
      bdayMsg = 'Your next birthday is tomorrow (' + fmtDate(nextBday) + ')';
    } else {
      bdayMsg = daysUntilBday + ' days until your next birthday (' + fmtDate(nextBday) + ')';
    }
    document.getElementById('birthday-countdown').textContent = bdayMsg;

    resultEl.style.display = '';
  };

  function fmtDate(d) {
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return months[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
  }
})();
</script>
