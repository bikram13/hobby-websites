<script>
(function () {
  'use strict';

  // Set target date default to today
  var todayISO = new Date().toISOString().slice(0, 10);
  document.getElementById('ac-target').value = todayISO;

  function pad(n) { return String(n).padStart(2, '0'); }

  function calcAge(dobStr, targetStr) {
    if (!dobStr || !targetStr) return null;

    // Parse as local dates (avoid UTC offset issues)
    var dobParts    = dobStr.split('-').map(Number);
    var targetParts = targetStr.split('-').map(Number);

    var dob    = new Date(dobParts[0], dobParts[1] - 1, dobParts[2]);
    var target = new Date(targetParts[0], targetParts[1] - 1, targetParts[2]);

    if (isNaN(dob) || isNaN(target) || target < dob) return null;

    // Total days
    var msPerDay  = 86400000;
    var totalDays = Math.floor((target - dob) / msPerDay);

    // Years / months / days — careful end-of-month handling
    var years  = target.getFullYear() - dob.getFullYear();
    var months = target.getMonth() - dob.getMonth();
    var days   = target.getDate() - dob.getDate();

    if (days < 0) {
      months -= 1;
      // How many days in the previous month of target?
      var prevMonth = new Date(target.getFullYear(), target.getMonth(), 0);
      days += prevMonth.getDate();
    }
    if (months < 0) {
      years  -= 1;
      months += 12;
    }

    var totalMonths = years * 12 + months;

    // Next birthday from DOB using target year
    var bdayThisYear = new Date(target.getFullYear(), dob.getMonth(), dob.getDate());
    var nextBday, prevBday;
    if (bdayThisYear >= target) {
      nextBday = bdayThisYear;
      prevBday = new Date(target.getFullYear() - 1, dob.getMonth(), dob.getDate());
    } else {
      nextBday = new Date(target.getFullYear() + 1, dob.getMonth(), dob.getDate());
      prevBday = bdayThisYear;
    }

    var daysUntilBday = Math.round((nextBday - target) / msPerDay);
    // progress in current year (0=birthday, 1=full year remaining)
    var yearMs = nextBday - prevBday;
    var elapsed = target - prevBday;
    var bdayPct = Math.max(0, Math.min(100, Math.round((elapsed / yearMs) * 100)));

    return {
      years: years,
      months: months,
      days: days,
      totalDays: totalDays,
      totalMonths: totalMonths,
      daysUntilBday: daysUntilBday,
      bdayPct: bdayPct
    };
  }

  function calculate() {
    var dob    = document.getElementById('ac-dob').value;
    var target = document.getElementById('ac-target').value;
    var r = calcAge(dob, target);

    if (!r) {
      ['ac-years','ac-months','ac-days','ac-total-months','ac-total-days','ac-bday-days'].forEach(function (id) {
        document.getElementById(id).textContent = '—';
      });
      document.getElementById('ac-bday-bar').style.width = '0%';
      return;
    }

    document.getElementById('ac-years').textContent       = r.years;
    document.getElementById('ac-months').textContent      = pad(r.months);
    document.getElementById('ac-days').textContent        = pad(r.days);
    document.getElementById('ac-total-months').textContent = r.totalMonths.toLocaleString();
    document.getElementById('ac-total-days').textContent   = r.totalDays.toLocaleString();
    document.getElementById('ac-bday-days').textContent    = r.daysUntilBday;
    document.getElementById('ac-bday-bar').style.width     = r.bdayPct + '%';
  }

  document.getElementById('ac-dob').addEventListener('change', calculate);
  document.getElementById('ac-target').addEventListener('change', calculate);
  document.getElementById('ac-calc-btn').addEventListener('click', calculate);

  // Auto-calculate on load
  calculate();
})();
</script>