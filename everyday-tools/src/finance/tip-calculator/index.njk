}
</style>

<script>
(function () {
  const billInput = document.getElementById('bill-amount');
  const peopleInput = document.getElementById('num-people');
  const customWrap = document.getElementById('custom-tip-wrap');
  const customInput = document.getElementById('custom-tip-input');
  const tipBtns = document.querySelectorAll('.tip-btn');
  const resTip = document.getElementById('res-tip');
  const resTotal = document.getElementById('res-total');
  const resPerPerson = document.getElementById('res-per-person');

  let currentTip = 18;
  let isCustom = false;

  function fmt(n) {
    return '$' + n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function calculate() {
    const bill = parseFloat(billInput.value) || 0;
    const people = Math.max(1, parseInt(peopleInput.value) || 1);
    const tipPct = isCustom ? (parseFloat(customInput.value) || 0) : currentTip;

    const tipAmt = bill * (tipPct / 100);
    const total = bill + tipAmt;
    const perPerson = total / people;

    if (bill === 0) {
      resTip.textContent = '—';
      resTotal.textContent = '—';
      resPerPerson.textContent = '—';
    } else {
      resTip.textContent = fmt(tipAmt);
      resTotal.textContent = fmt(total);
      resPerPerson.textContent = fmt(perPerson);
    }
  }

  tipBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      tipBtns.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      if (btn.dataset.tip === 'custom') {
        isCustom = true;
        customWrap.style.display = 'block';
        customInput.focus();
      } else {
        isCustom = false;
        currentTip = parseFloat(btn.dataset.tip);
        customWrap.style.display = 'none';
      }
      calculate();
    });
  });

  customInput.addEventListener('input', calculate);
  billInput.addEventListener('input', calculate);
  peopleInput.addEventListener('input', calculate);

  calculate();
})();
</script>
