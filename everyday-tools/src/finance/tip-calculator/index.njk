.field-group input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
.field-group input[type="number"]:focus { outline: 2px solid var(--color-accent); outline-offset: 1px; border-color: transparent; }

.input-prefix-wrap, .input-suffix-wrap { position: relative; }
.input-prefix { position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: var(--color-text-muted); pointer-events: none; font-size: 1rem; }
.input-prefix-wrap input { padding-left: 1.75rem; }
.input-suffix { position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%); color: var(--color-text-muted); pointer-events: none; font-size: 1rem; }
.input-suffix-wrap input { padding-right: 2.25rem; }

.tip-btn-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
