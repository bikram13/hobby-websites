<script>
(function () {
  var principalInput = document.getElementById('principal');
  var rateInput = document.getElementById('interest-rate');
  var tenureInput = document.getElementById('tenure');
  var tenureBtns = document.querySelectorAll('.tenure-btn');
  var resEmi = document.getElementById('res-emi');
  var resInterest = document.getElementById('res-interest');
  var resTotalPayment = document.getElementById('res-total-payment');

  var tenureUnit = 'years';

  function fmt(n) {
    return '₹' + Math.round(n).toLocaleString('en-IN');
  }

  function calculate() {
    var P = parseFloat(principalInput.value);
    var annualRate = parseFloat(rateInput.value);
    var tenureVal = parseFloat(tenureInput.value);

    if (!P || !annualRate || !tenureVal || P <= 0 || annualRate <= 0 || tenureVal <= 0) {
      resEmi.textContent = '—';
      resInterest.textContent = '—';
      resTotalPayment.textContent = '—';
      return;
    }

    var n = tenureUnit === 'years' ? tenureVal * 12 : tenureVal;
    var r = annualRate / 12 / 100;

    var emi;
    if (r === 0) {
      emi = P / n;
    } else {
      var pow = Math.pow(1 + r, n);
      emi = (P * r * pow) / (pow - 1);
    }

    var totalPayment = emi * n;
    var totalInterest = totalPayment - P;

    resEmi.textContent = fmt(emi);
    resInterest.textContent = fmt(totalInterest);
    resTotalPayment.textContent = fmt(totalPayment);
  }

  tenureBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      tenureBtns.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      tenureUnit = btn.dataset.unit;
      calculate();
    });
  });

  principalInput.addEventListener('input', calculate);
  rateInput.addEventListener('input', calculate);
  tenureInput.addEventListener('input', calculate);

  calculate();
})();
</script>
