<script>
(function () {
  var tabs = document.querySelectorAll('.pct-tab');
  var panels = document.querySelectorAll('.pct-panel');

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      tabs.forEach(function (t) { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach(function (p) { p.classList.remove('active'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      document.getElementById('panel-' + tab.dataset.mode).classList.add('active');
    });
  });

  function fmt(n) {
    var rounded = Math.round(n * 10000) / 10000;
    return rounded % 1 === 0 ? rounded.toString() : parseFloat(rounded.toFixed(4)).toString();
  }

  // Mode 1: X% of Y
  var ofPct = document.getElementById('of-pct');
  var ofNum = document.getElementById('of-num');
  var resOf = document.getElementById('res-of');

  function calcOf() {
    var x = parseFloat(ofPct.value);
    var y = parseFloat(ofNum.value);
    if (isNaN(x) || isNaN(y)) { resOf.textContent = '—'; return; }
    resOf.textContent = fmt((x / 100) * y);
  }
  ofPct.addEventListener('input', calcOf);
  ofNum.addEventListener('input', calcOf);

  // Mode 2: X is what % of Y
  var whatX = document.getElementById('what-x');
  var whatY = document.getElementById('what-y');
  var resWhat = document.getElementById('res-what');

  function calcWhat() {
    var x = parseFloat(whatX.value);
    var y = parseFloat(whatY.value);
    if (isNaN(x) || isNaN(y) || y === 0) { resWhat.textContent = '—'; return; }
    resWhat.textContent = fmt((x / y) * 100) + '%';
  }
  whatX.addEventListener('input', calcWhat);
  whatY.addEventListener('input', calcWhat);

  // Mode 3: % Change
  var changeFrom = document.getElementById('change-from');
  var changeTo = document.getElementById('change-to');
  var resChange = document.getElementById('res-change');
  var changeBox = document.getElementById('change-result-box');

  function calcChange() {
    var from = parseFloat(changeFrom.value);
    var to = parseFloat(changeTo.value);
    changeBox.classList.remove('pct-increase', 'pct-decrease');
    if (isNaN(from) || isNaN(to) || from === 0) { resChange.textContent = '—'; return; }
    var change = ((to - from) / Math.abs(from)) * 100;
    resChange.textContent = (change >= 0 ? '+' : '') + fmt(change) + '%';
    if (change > 0) changeBox.classList.add('pct-increase');
    else if (change < 0) changeBox.classList.add('pct-decrease');
  }
  changeFrom.addEventListener('input', calcChange);
  changeTo.addEventListener('input', calcChange);
})();
</script>
