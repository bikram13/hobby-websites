<li class="flex justify-between"><span>1 kg</span> <span>2.20462 lb</span></li>
<li class="flex justify-between"><span>1 lb</span> <span>0.45359 kg</span></li>
<li class="flex justify-between"><span>1 oz</span> <span>28.3495 g</span></li>
</ul>
</div>
