---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'case-converter')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['Writing']}>
  <nav style="margin-bottom:1.5rem;">
    <a href="/" style="color:#b9c3ff; text-decoration:none; font-size:0.875rem;">← All Tools</a>
  </nav>
  <div style="margin-bottom:2.5rem;">
    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-0.025em; color:#e4e2e4; margin:0 0 0.75rem;">{tool.title}</h1>
    <p style="color:#c5c5d5; font-size:1.05rem; margin:0; max-width:36rem; line-height:1.6;">{tool.description}</p>
  </div>

  <!-- Input -->
  <textarea
    id="cc-input"
    rows="8"
    placeholder="Type or paste your text here…"
    class="w-full" style="border-radius:0.5rem; padding:1rem; font-size:1rem; resize:vertical; width:100%;"
  ></textarea>

  <!-- Conversion buttons -->
  <div class="mt-4 flex flex-wrap gap-2">
    <button data-case="upper"    class="cc-btn btn-ghost" style="padding:0.5rem 1rem; border-radius:0.5rem; font-size:0.875rem;">UPPER CASE</button>
    <button data-case="lower"    class="cc-btn btn-ghost" style="padding:0.5rem 1rem; border-radius:0.5rem; font-size:0.875rem;">lower case</button>
    <button data-case="title"    class="cc-btn btn-ghost" style="padding:0.5rem 1rem; border-radius:0.5rem; font-size:0.875rem;">Title Case</button>
    <button data-case="sentence" class="cc-btn btn-ghost" style="padding:0.5rem 1rem; border-radius:0.5rem; font-size:0.875rem;">Sentence case</button>
    <button data-case="camel"    class="cc-btn btn-ghost" style="padding:0.5rem 1rem; border-radius:0.5rem; font-size:0.875rem;">camelCase</button>
    <button data-case="snake"    class="cc-btn btn-ghost" style="padding:0.5rem 1rem; border-radius:0.5rem; font-size:0.875rem;">snake_case</button>
    <button data-case="kebab"    class="cc-btn btn-ghost" style="padding:0.5rem 1rem; border-radius:0.5rem; font-size:0.875rem;">kebab-case</button>
  </div>

  <!-- Output -->
  <div class="mt-6 relative">
    <label class="block text-sm font-medium mb-2" style="color:#c5c5d5;">Result</label>
    <textarea
      id="cc-output"
      rows="8"
      readonly
      placeholder="Converted text will appear here…"
      class="w-full" style="border-radius:0.5rem; padding:1rem; font-size:1rem; resize:vertical; width:100%; background:#1b1b1d;"
    ></textarea>
    <button
      id="cc-copy"
      class="absolute top-9 right-3"
      style="background:linear-gradient(135deg,#7189f6,#5c3187); color:#fff; border:none; border-radius:0.375rem; padding:0.375rem 0.75rem; font-size:0.75rem; font-weight:700; cursor:pointer;"
    >Copy</button>
  </div>

  <!-- Stats -->
  <div class="mt-4 flex gap-6 text-sm" style="color:#8f909e;">
    <span>Characters: <strong id="cc-chars" style="color:#e4e2e4;">0</strong></span>
    <span>Words: <strong id="cc-words" style="color:#e4e2e4;">0</strong></span>
  </div>

  <!-- Explanation -->
  <section class="glass-card" style="margin-top:2.5rem; padding:1.5rem;">
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">About Case Converter</h2>
    <ul class="space-y-2 text-sm" style="color:#c5c5d5;">
      <li><span style="color:#e4e2e4; font-weight:600;">UPPER CASE</span> — every letter becomes uppercase.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">lower case</span> — every letter becomes lowercase.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">Title Case</span> — first letter of each word capitalised.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">Sentence case</span> — first letter of each sentence capitalised, rest lowercased.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">camelCase</span> — words joined with no spaces; first word lowercase, subsequent words capitalised. Useful for variable names.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">snake_case</span> — words joined with underscores, all lowercase. Common in Python and databases.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">kebab-case</span> — words joined with hyphens, all lowercase. Used in URLs and CSS class names.</li>
    </ul>
  </section>
</BaseLayout>

<script>
  const input  = document.getElementById('cc-input')  as HTMLTextAreaElement
  const output = document.getElementById('cc-output') as HTMLTextAreaElement
  const copyBtn = document.getElementById('cc-copy')  as HTMLButtonElement
  const elChars = document.getElementById('cc-chars')!
  const elWords = document.getElementById('cc-words')!

  // ── helpers ──────────────────────────────────────────────────────────────────

  function words(text: string): string[] {
    return text.trim().split(/[\s\-_]+/).filter(Boolean)
  }

  function toUpper(t: string)    { return t.toUpperCase() }
  function toLower(t: string)    { return t.toLowerCase() }
  function toTitle(t: string)    { return t.replace(/\S+/g, w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()) }
  function toSentence(t: string) {
    return t.toLowerCase().replace(/(^\s*\w|[.!?]\s+\w)/g, c => c.toUpperCase())
  }
  function toCamel(t: string) {
    const ws = words(t)
    return ws.map((w, i) => i === 0 ? w.toLowerCase() : w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join('')
  }
  function toSnake(t: string)   { return words(t).map(w => w.toLowerCase()).join('_') }
  function toKebab(t: string)   { return words(t).map(w => w.toLowerCase()).join('-') }

  const converters: Record<string, (t: string) => string> = {
    upper: toUpper, lower: toLower, title: toTitle,
    sentence: toSentence, camel: toCamel, snake: toSnake, kebab: toKebab,
  }

  // ── state ────────────────────────────────────────────────────────────────────

  function updateStats(text: string) {
    elChars.textContent = text.length.toLocaleString()
    elWords.textContent = (text.trim() === '' ? 0 : text.trim().split(/\s+/).length).toLocaleString()
  }

  function apply(caseType: string) {
    const text = input.value
    if (!converters[caseType]) {
      output.value = ''
      output.placeholder = `Unknown case type: "${caseType}"`
      return
    }
    const converted = converters[caseType](text)
    output.value = converted
    updateStats(converted)
  }

  // localStorage persistence
  const LS_KEY = 'cc-input'
  const saved = localStorage.getItem(LS_KEY)
  if (saved) { input.value = saved; updateStats(saved) }
  input.addEventListener('input', () => {
    localStorage.setItem(LS_KEY, input.value)
    updateStats(input.value)
  })

  // Case buttons
  document.querySelectorAll<HTMLButtonElement>('.cc-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const caseType = btn.dataset.case ?? ''
      apply(caseType)
      // Brief active highlight
      btn.classList.add('bg-blue-100', 'border-blue-500', 'text-blue-800')
      setTimeout(() => btn.classList.remove('bg-blue-100', 'border-blue-500', 'text-blue-800'), 400)
    })
  })

  // Copy
  copyBtn.addEventListener('click', async () => {
    const text = output.value
    if (!text) return
    try {
      await navigator.clipboard.writeText(text)
    } catch {
      // Fallback for older browsers
      output.select()
      document.execCommand('copy')
    }
    copyBtn.textContent = 'Copied!'
    copyBtn.classList.replace('bg-blue-600', 'bg-green-600')
    setTimeout(() => {
      copyBtn.textContent = 'Copy'
      copyBtn.classList.replace('bg-green-600', 'bg-blue-600')
    }, 1500)
  })
</script>
