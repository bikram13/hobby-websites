---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'text-diff')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['Writing']}>
  <nav style="margin-bottom:1.5rem;">
    <a href="/" style="color:#b9c3ff; text-decoration:none; font-size:0.875rem;">← All Tools</a>
  </nav>
  <div style="margin-bottom:2.5rem;">
    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-0.025em; color:#e4e2e4; margin:0 0 0.75rem;">{tool.title}</h1>
    <p style="color:#c5c5d5; font-size:1.05rem; margin:0; max-width:36rem; line-height:1.6;">{tool.description}</p>
  </div>

  <div id="diff-app">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
      <div>
        <label class="block font-semibold text-sm mb-1" style="color:#c5c5d5;">Original Text</label>
        <textarea id="diff-original" style="width:100%;min-height:160px;padding:.6rem .75rem;border:1px solid rgba(68,70,83,0.4);border-radius:.5rem;font-size:.9rem;line-height:1.6;resize:vertical;box-sizing:border-box" placeholder="Paste original text here…"></textarea>
      </div>
      <div>
        <label class="block font-semibold text-sm mb-1" style="color:#c5c5d5;">New Text</label>
        <textarea id="diff-revised" style="width:100%;min-height:160px;padding:.6rem .75rem;border:1px solid rgba(68,70,83,0.4);border-radius:.5rem;font-size:.9rem;line-height:1.6;resize:vertical;box-sizing:border-box" placeholder="Paste revised text here…"></textarea>
      </div>
    </div>

    <div style="display:flex;gap:.5rem;margin-bottom:1rem;align-items:center;flex-wrap:wrap">
      <span style="font-size:.8rem;color:#8f909e">View:</span>
      <button id="btn-side" style="padding:.3rem .75rem;border-radius:999px;border:1px solid #7189f6;background:#7189f6;color:#fff;font-size:.8rem;cursor:pointer">Side-by-side</button>
      <button id="btn-unified" style="padding:.3rem .75rem;border-radius:999px;border:1px solid rgba(68,70,83,0.4);background:rgba(53,52,55,0.55);color:#c5c5d5;font-size:.8rem;cursor:pointer">Unified</button>
      <span id="diff-stats" style="font-size:.85rem;margin-left:.5rem"></span>
    </div>

    <div id="diff-output" style="padding:2rem;text-align:center;color:#8f909e;background:#1b1b1d;border-radius:.75rem;border:1px solid rgba(68,70,83,0.4)">
      Paste text in both boxes to see differences
    </div>
  </div>

  <script>
    // Load diff library from CDN
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/diff@7/dist/diff.min.js';
    s.onload = initDiff;
    document.head.appendChild(s);

    let view = 'side';
    let lastChanges = null;

    function initDiff() {
      const origEl = document.getElementById('diff-original');
      const revEl = document.getElementById('diff-revised');
      const outEl = document.getElementById('diff-output');
      const statsEl = document.getElementById('diff-stats');
      const btnSide = document.getElementById('btn-side');
      const btnUnified = document.getElementById('btn-unified');

      function setView(v) {
        view = v;
        btnSide.style.background = v === 'side' ? '#7189f6' : 'rgba(53,52,55,0.55)';
        btnSide.style.color = v === 'side' ? '#fff' : '#c5c5d5';
        btnSide.style.borderColor = v === 'side' ? '#7189f6' : 'rgba(68,70,83,0.4)';
        btnUnified.style.background = v === 'unified' ? '#7189f6' : 'rgba(53,52,55,0.55)';
        btnUnified.style.color = v === 'unified' ? '#fff' : '#c5c5d5';
        btnUnified.style.borderColor = v === 'unified' ? '#7189f6' : 'rgba(68,70,83,0.4)';
        if (lastChanges) render(lastChanges);
      }

      function wordCount(str) {
        return str.trim() ? str.trim().split(/\s+/).length : 0;
      }

      function render(changes) {
        let added = 0, removed = 0, unchanged = 0;
        changes.forEach(c => {
          const w = wordCount(c.value);
          if (c.added) added += w;
          else if (c.removed) removed += w;
          else unchanged += w;
        });
        statsEl.innerHTML = `<span style="color:#4edea3;font-weight:600">+${added} added</span> &nbsp; <span style="color:#f87171;font-weight:600">−${removed} removed</span> &nbsp; <span style="color:#8f909e">${unchanged} unchanged</span>`;

        if (view === 'side') {
          let left = '', right = '';
          changes.forEach(c => {
            const safe = c.value.replace(/&/g,'&amp;').replace(/</g,'&lt;');
            if (c.removed) left += `<del style="background:rgba(248,113,113,0.2);border-radius:2px;text-decoration:line-through;color:#fca5a5">${safe}</del>`;
            else if (c.added) right += `<mark style="background:rgba(78,222,163,0.2);border-radius:2px;color:#4edea3">${safe}</mark>`;
            else { left += safe; right += safe; }
          });
          outEl.innerHTML = `<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div style="background:rgba(248,113,113,0.05);border:1px solid rgba(248,113,113,0.2);border-radius:.5rem;padding:.75rem;line-height:1.7;font-size:.9rem;white-space:pre-wrap;word-break:break-word;color:#c5c5d5"><div style="font-weight:600;margin-bottom:.5rem;color:#f87171;font-size:.75rem;text-transform:uppercase">Original</div>${left}</div>
            <div style="background:rgba(78,222,163,0.05);border:1px solid rgba(78,222,163,0.2);border-radius:.5rem;padding:.75rem;line-height:1.7;font-size:.9rem;white-space:pre-wrap;word-break:break-word;color:#c5c5d5"><div style="font-weight:600;margin-bottom:.5rem;color:#4edea3;font-size:.75rem;text-transform:uppercase">Revised</div>${right}</div>
          </div>`;
        } else {
          let out = '';
          changes.forEach(c => {
            const safe = c.value.replace(/&/g,'&amp;').replace(/</g,'&lt;');
            if (c.added) out += `<mark style="background:rgba(78,222,163,0.2);border-radius:2px;color:#4edea3">${safe}</mark>`;
            else if (c.removed) out += `<del style="background:rgba(248,113,113,0.2);border-radius:2px;text-decoration:line-through;color:#fca5a5">${safe}</del>`;
            else out += safe;
          });
          outEl.innerHTML = `<div style="background:#1b1b1d;border:1px solid rgba(68,70,83,0.4);border-radius:.5rem;padding:.75rem;line-height:1.7;font-size:.9rem;white-space:pre-wrap;word-break:break-word;color:#c5c5d5">${out}</div>`;
        }
      }

      function runDiff() {
        const orig = origEl.value, rev = revEl.value;
        if (!orig.trim() && !rev.trim()) {
          outEl.innerHTML = 'Paste text in both boxes to see differences';
          statsEl.textContent = '';
          lastChanges = null;
          return;
        }
        lastChanges = Diff.diffWords(orig, rev);
        render(lastChanges);
      }

      origEl.addEventListener('input', runDiff);
      revEl.addEventListener('input', runDiff);
      btnSide.addEventListener('click', () => setView('side'));
      btnUnified.addEventListener('click', () => setView('unified'));
    }
  </script>

  <section class="glass-card" style="margin-top:2.5rem; padding:1.5rem;">
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">How the Text Diff Tool Works</h2>
    <p style="color:#c5c5d5; margin:0 0 1rem;">Paste your original and revised text into the two boxes. The tool compares them word-by-word and highlights changes instantly. Added words appear with a green background; removed words appear with a red strikethrough.</p>
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">Side-by-side vs Unified view</h2>
    <p style="color:#c5c5d5; margin:0 0 1rem;"><strong style="color:#e4e2e4;">Side-by-side</strong> shows original on the left with removals highlighted, and revised on the right with additions highlighted. <strong style="color:#e4e2e4;">Unified</strong> shows both in a single stream.</p>
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">Common uses</h2>
    <ul style="color:#c5c5d5; padding-left:1.25rem; margin:0;">
      <li>Comparing draft versions of an article or email</li>
      <li>Checking what changed in a copied document</li>
      <li>Reviewing edits before sending to a client</li>
      <li>Comparing two versions of code snippets or config files</li>
    </ul>
  </section>
</BaseLayout>
