---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'

const tool = tools.find(t => t.slug === 'text-diff')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
---
<BaseLayout title={title} description={description}>
  <nav class="mb-6"><a href="/" class="text-blue-600 hover:text-blue-800 text-sm">← All Tools</a></nav>
  <h1 class="text-3xl font-bold text-gray-900 mb-3">{tool.title}</h1>
  <p class="text-gray-600 text-lg mb-8">{tool.description}</p>

  <div id="diff-app">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
      <div>
        <label class="block font-semibold text-sm mb-1 text-gray-700">Original Text</label>
        <textarea id="diff-original" style="width:100%;min-height:160px;padding:.6rem .75rem;border:1px solid #d1d5db;border-radius:.5rem;font-size:.9rem;line-height:1.6;resize:vertical;box-sizing:border-box" placeholder="Paste original text here…"></textarea>
      </div>
      <div>
        <label class="block font-semibold text-sm mb-1 text-gray-700">New Text</label>
        <textarea id="diff-revised" style="width:100%;min-height:160px;padding:.6rem .75rem;border:1px solid #d1d5db;border-radius:.5rem;font-size:.9rem;line-height:1.6;resize:vertical;box-sizing:border-box" placeholder="Paste revised text here…"></textarea>
      </div>
    </div>

    <div style="display:flex;gap:.5rem;margin-bottom:1rem;align-items:center;flex-wrap:wrap">
      <span style="font-size:.8rem;color:#6b7280">View:</span>
      <button id="btn-side" style="padding:.3rem .75rem;border-radius:999px;border:1px solid #2563eb;background:#2563eb;color:#fff;font-size:.8rem;cursor:pointer">Side-by-side</button>
      <button id="btn-unified" style="padding:.3rem .75rem;border-radius:999px;border:1px solid #d1d5db;background:#fff;color:#374151;font-size:.8rem;cursor:pointer">Unified</button>
      <span id="diff-stats" style="font-size:.85rem;margin-left:.5rem"></span>
    </div>

    <div id="diff-output" style="padding:2rem;text-align:center;color:#9ca3af;background:#f9fafb;border-radius:.75rem;border:1px solid #e5e7eb">
      Paste text in both boxes to see differences
    </div>
  </div>

  <script>
    // Load diff library from CDN
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/diff@7/dist/diff.min.js';
    s.onload = initDiff;
    document.head.appendChild(s);

    let view = 'side';
    let lastChanges = null;

    function initDiff() {
      const origEl = document.getElementById('diff-original');
      const revEl = document.getElementById('diff-revised');
      const outEl = document.getElementById('diff-output');
      const statsEl = document.getElementById('diff-stats');
      const btnSide = document.getElementById('btn-side');
      const btnUnified = document.getElementById('btn-unified');

      function setView(v) {
        view = v;
        btnSide.style.background = v === 'side' ? '#2563eb' : '#fff';
        btnSide.style.color = v === 'side' ? '#fff' : '#374151';
        btnSide.style.borderColor = v === 'side' ? '#2563eb' : '#d1d5db';
        btnUnified.style.background = v === 'unified' ? '#2563eb' : '#fff';
        btnUnified.style.color = v === 'unified' ? '#fff' : '#374151';
        btnUnified.style.borderColor = v === 'unified' ? '#2563eb' : '#d1d5db';
        if (lastChanges) render(lastChanges);
      }

      function wordCount(str) {
        return str.trim() ? str.trim().split(/\s+/).length : 0;
      }

      function render(changes) {
        let added = 0, removed = 0, unchanged = 0;
        changes.forEach(c => {
          const w = wordCount(c.value);
          if (c.added) added += w;
          else if (c.removed) removed += w;
          else unchanged += w;
        });
        statsEl.innerHTML = `<span style="color:#16a34a;font-weight:600">+${added} added</span> &nbsp; <span style="color:#dc2626;font-weight:600">−${removed} removed</span> &nbsp; <span style="color:#6b7280">${unchanged} unchanged</span>`;

        if (view === 'side') {
          let left = '', right = '';
          changes.forEach(c => {
            const safe = c.value.replace(/&/g,'&amp;').replace(/</g,'&lt;');
            if (c.removed) left += `<del style="background:#fecaca;border-radius:2px;text-decoration:line-through">${safe}</del>`;
            else if (c.added) right += `<mark style="background:#bbf7d0;border-radius:2px">${safe}</mark>`;
            else { left += safe; right += safe; }
          });
          outEl.innerHTML = `<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div style="background:#fff7f7;border:1px solid #fecaca;border-radius:.5rem;padding:.75rem;line-height:1.7;font-size:.9rem;white-space:pre-wrap;word-break:break-word"><div style="font-weight:600;margin-bottom:.5rem;color:#dc2626;font-size:.75rem;text-transform:uppercase">Original</div>${left}</div>
            <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:.5rem;padding:.75rem;line-height:1.7;font-size:.9rem;white-space:pre-wrap;word-break:break-word"><div style="font-weight:600;margin-bottom:.5rem;color:#16a34a;font-size:.75rem;text-transform:uppercase">Revised</div>${right}</div>
          </div>`;
        } else {
          let out = '';
          changes.forEach(c => {
            const safe = c.value.replace(/&/g,'&amp;').replace(/</g,'&lt;');
            if (c.added) out += `<mark style="background:#bbf7d0;border-radius:2px">${safe}</mark>`;
            else if (c.removed) out += `<del style="background:#fecaca;border-radius:2px;text-decoration:line-through">${safe}</del>`;
            else out += safe;
          });
          outEl.innerHTML = `<div style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:.5rem;padding:.75rem;line-height:1.7;font-size:.9rem;white-space:pre-wrap;word-break:break-word">${out}</div>`;
        }
      }

      function runDiff() {
        const orig = origEl.value, rev = revEl.value;
        if (!orig.trim() && !rev.trim()) {
          outEl.innerHTML = 'Paste text in both boxes to see differences';
          statsEl.textContent = '';
          lastChanges = null;
          return;
        }
        lastChanges = Diff.diffWords(orig, rev);
        render(lastChanges);
      }

      origEl.addEventListener('input', runDiff);
      revEl.addEventListener('input', runDiff);
      btnSide.addEventListener('click', () => setView('side'));
      btnUnified.addEventListener('click', () => setView('unified'));
    }
  </script>

  <section class="mt-12 prose prose-gray max-w-none">
    <h2>How the Text Diff Tool Works</h2>
    <p>Paste your original and revised text into the two boxes. The tool compares them word-by-word and highlights changes instantly. Added words appear with a green background; removed words appear with a red strikethrough.</p>
    <h2>Side-by-side vs Unified view</h2>
    <p><strong>Side-by-side</strong> shows original on the left with removals highlighted, and revised on the right with additions highlighted. <strong>Unified</strong> shows both in a single stream.</p>
    <h2>Common uses</h2>
    <ul>
      <li>Comparing draft versions of an article or email</li>
      <li>Checking what changed in a copied document</li>
      <li>Reviewing edits before sending to a client</li>
      <li>Comparing two versions of code snippets or config files</li>
    </ul>
  </section>
</BaseLayout>
