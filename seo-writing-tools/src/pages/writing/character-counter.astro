---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'character-counter')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['Writing']}>
  <nav style="margin-bottom:1.5rem;">
    <a href="/" style="color:#b9c3ff; text-decoration:none; font-size:0.875rem;">← All Tools</a>
  </nav>
  <div style="margin-bottom:2.5rem;">
    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-0.025em; color:#e4e2e4; margin:0 0 0.75rem;">{tool.title}</h1>
    <p style="color:#c5c5d5; font-size:1.05rem; margin:0; max-width:36rem; line-height:1.6;">{tool.description}</p>
  </div>

  <textarea
    id="cc-input"
    rows="12"
    placeholder="Paste or type your text here…"
    class="w-full" style="border-radius:0.5rem; padding:1rem; font-size:1rem; resize:vertical; width:100%;"
  ></textarea>

  <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div class="glass-card" style="padding:1.5rem; text-align:center;">
      <p id="cc-with-spaces" style="font-size:2.25rem; font-weight:700; color:#b9c3ff; margin:0;">0</p>
      <p class="mt-2 text-base font-medium" style="color:#e4e2e4;">Characters with spaces</p>
      <p class="mt-1 text-sm" style="color:#8f909e;">Total length of your text</p>
    </div>
    <div class="glass-card" style="padding:1.5rem; text-align:center;">
      <p id="cc-without-spaces" style="font-size:2.25rem; font-weight:700; color:#b9c3ff; margin:0;">0</p>
      <p class="mt-2 text-base font-medium" style="color:#e4e2e4;">Characters without spaces</p>
      <p class="mt-1 text-sm" style="color:#8f909e;">Spaces and newlines excluded</p>
    </div>
  </div>

  <!-- Common limits reference -->
  <div class="mt-6 glass-card" style="padding:1.25rem; background:rgba(185,195,255,0.05);">
    <h2 class="text-sm font-semibold uppercase tracking-wide mb-3" style="color:#b9c3ff;">Common character limits</h2>
    <div class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
      <div class="flex justify-between">
        <span style="color:#c5c5d5;">Twitter / X post</span>
        <span id="limit-twitter" class="font-medium" style="color:#e4e2e4;">280 remaining</span>
      </div>
      <div class="flex justify-between">
        <span style="color:#c5c5d5;">Meta description</span>
        <span id="limit-meta" class="font-medium" style="color:#e4e2e4;">160 remaining</span>
      </div>
      <div class="flex justify-between">
        <span style="color:#c5c5d5;">Meta title</span>
        <span id="limit-title" class="font-medium" style="color:#e4e2e4;">60 remaining</span>
      </div>
      <div class="flex justify-between">
        <span style="color:#c5c5d5;">LinkedIn post</span>
        <span id="limit-linkedin" class="font-medium" style="color:#e4e2e4;">3000 remaining</span>
      </div>
    </div>
  </div>

  <section class="glass-card" style="margin-top:2.5rem; padding:1.5rem;">
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">When does character count matter?</h2>
    <ul class="space-y-2 text-sm" style="color:#c5c5d5;">
      <li><span style="color:#e4e2e4; font-weight:600;">SEO meta descriptions</span> — Google typically truncates after ~160 characters in search results.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">Page titles</span> — keep titles under 60 characters to avoid truncation in SERPs.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">Social posts</span> — Twitter/X enforces a 280-character hard limit; LinkedIn allows up to 3,000.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">Without spaces</span> — useful when a platform counts only visible characters, or for comparing raw content density.</li>
    </ul>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('cc-input') as HTMLTextAreaElement
  const elWith    = document.getElementById('cc-with-spaces')!
  const elWithout = document.getElementById('cc-without-spaces')!

  const elTwitter  = document.getElementById('limit-twitter')!
  const elMeta     = document.getElementById('limit-meta')!
  const elTitle    = document.getElementById('limit-title')!
  const elLinkedin = document.getElementById('limit-linkedin')!

  function limitLabel(count: number, limit: number): string {
    const remaining = limit - count
    if (remaining >= 0) return `${remaining} remaining`
    return `${Math.abs(remaining)} over limit`
  }

  function limitClass(count: number, limit: number): string {
    const remaining = limit - count
    if (remaining < 0) return 'text-red-600'
    if (remaining < limit * 0.1) return 'text-amber-600'
    return 'text-gray-900'
  }

  function update() {
    const text = input.value
    const withSpaces    = text.length
    const withoutSpaces = text.replace(/\s/g, '').length

    elWith.textContent    = withSpaces.toLocaleString()
    elWithout.textContent = withoutSpaces.toLocaleString()

    const limits: [HTMLElement, number][] = [
      [elTwitter,  280],
      [elMeta,     160],
      [elTitle,     60],
      [elLinkedin, 3000],
    ]

    for (const [el, limit] of limits) {
      el.textContent = limitLabel(withSpaces, limit)
      el.className   = `font-medium ${limitClass(withSpaces, limit)}`
    }
  }

  input.addEventListener('input', update)
</script>
