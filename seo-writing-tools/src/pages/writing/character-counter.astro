---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'character-counter')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['Writing']}>
  <nav class="mb-6"><a href="/" class="text-blue-600 hover:text-blue-800 text-sm">← All Tools</a></nav>
  <h1 class="text-3xl font-bold text-gray-900 mb-3">{tool.title}</h1>
  <p class="text-gray-600 text-lg mb-6">{tool.description}</p>

  <textarea
    id="cc-input"
    rows="12"
    placeholder="Paste or type your text here…"
    class="w-full rounded-lg border border-gray-300 bg-white p-4 text-base text-gray-800 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200 resize-y"
  ></textarea>

  <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div class="rounded-lg border border-gray-200 bg-white p-6 text-center shadow-sm">
      <p id="cc-with-spaces" class="text-4xl font-bold text-blue-600">0</p>
      <p class="mt-2 text-base font-medium text-gray-700">Characters with spaces</p>
      <p class="mt-1 text-sm text-gray-500">Total length of your text</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-6 text-center shadow-sm">
      <p id="cc-without-spaces" class="text-4xl font-bold text-blue-600">0</p>
      <p class="mt-2 text-base font-medium text-gray-700">Characters without spaces</p>
      <p class="mt-1 text-sm text-gray-500">Spaces and newlines excluded</p>
    </div>
  </div>

  <!-- Common limits reference -->
  <div class="mt-6 rounded-lg border border-blue-100 bg-blue-50 p-5">
    <h2 class="text-sm font-semibold text-blue-800 mb-3 uppercase tracking-wide">Common character limits</h2>
    <div class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
      <div class="flex justify-between">
        <span class="text-gray-700">Twitter / X post</span>
        <span id="limit-twitter" class="font-medium text-gray-900">280 remaining</span>
      </div>
      <div class="flex justify-between">
        <span class="text-gray-700">Meta description</span>
        <span id="limit-meta" class="font-medium text-gray-900">160 remaining</span>
      </div>
      <div class="flex justify-between">
        <span class="text-gray-700">Meta title</span>
        <span id="limit-title" class="font-medium text-gray-900">60 remaining</span>
      </div>
      <div class="flex justify-between">
        <span class="text-gray-700">LinkedIn post</span>
        <span id="limit-linkedin" class="font-medium text-gray-900">3000 remaining</span>
      </div>
    </div>
  </div>

  <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-gray-800 mb-3">When does character count matter?</h2>
    <ul class="space-y-2 text-sm text-gray-600">
      <li><span class="font-medium text-gray-700">SEO meta descriptions</span> — Google typically truncates after ~160 characters in search results.</li>
      <li><span class="font-medium text-gray-700">Page titles</span> — keep titles under 60 characters to avoid truncation in SERPs.</li>
      <li><span class="font-medium text-gray-700">Social posts</span> — Twitter/X enforces a 280-character hard limit; LinkedIn allows up to 3,000.</li>
      <li><span class="font-medium text-gray-700">Without spaces</span> — useful when a platform counts only visible characters, or for comparing raw content density.</li>
    </ul>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('cc-input') as HTMLTextAreaElement
  const elWith    = document.getElementById('cc-with-spaces')!
  const elWithout = document.getElementById('cc-without-spaces')!

  const elTwitter  = document.getElementById('limit-twitter')!
  const elMeta     = document.getElementById('limit-meta')!
  const elTitle    = document.getElementById('limit-title')!
  const elLinkedin = document.getElementById('limit-linkedin')!

  function limitLabel(count: number, limit: number): string {
    const remaining = limit - count
    if (remaining >= 0) return `${remaining} remaining`
    return `${Math.abs(remaining)} over limit`
  }

  function limitClass(count: number, limit: number): string {
    const remaining = limit - count
    if (remaining < 0) return 'text-red-600'
    if (remaining < limit * 0.1) return 'text-amber-600'
    return 'text-gray-900'
  }

  function update() {
    const text = input.value
    const withSpaces    = text.length
    const withoutSpaces = text.replace(/\s/g, '').length

    elWith.textContent    = withSpaces.toLocaleString()
    elWithout.textContent = withoutSpaces.toLocaleString()

    const limits: [HTMLElement, number][] = [
      [elTwitter,  280],
      [elMeta,     160],
      [elTitle,     60],
      [elLinkedin, 3000],
    ]

    for (const [el, limit] of limits) {
      el.textContent = limitLabel(withSpaces, limit)
      el.className   = `font-medium ${limitClass(withSpaces, limit)}`
    }
  }

  input.addEventListener('input', update)
</script>
