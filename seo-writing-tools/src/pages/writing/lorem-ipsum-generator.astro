---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'

const tool = tools.find(t => t.slug === 'lorem-ipsum-generator')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
---
<BaseLayout title={title} description={description}>
  <nav class="mb-6"><a href="/" class="text-blue-600 hover:text-blue-800 text-sm">← All Tools</a></nav>
  <h1 class="text-3xl font-bold text-gray-900 mb-3">{tool.title}</h1>
  <p class="text-gray-600 text-lg mb-6">{tool.description}</p>

  <!-- Controls -->
  <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
    <div class="flex flex-wrap gap-6 items-end">

      <!-- Mode selector -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="li-mode">Generate</label>
        <select
          id="li-mode"
          class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
        >
          <option value="paragraphs">Paragraphs</option>
          <option value="sentences">Sentences</option>
          <option value="words">Words</option>
        </select>
      </div>

      <!-- Number input -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1" for="li-count">Amount</label>
        <input
          id="li-count"
          type="number"
          value="3"
          min="1"
          max="20"
          class="w-24 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
        />
      </div>

      <!-- Classic opener checkbox -->
      <div class="flex items-center gap-2 pb-0.5">
        <input
          id="li-classic"
          type="checkbox"
          checked
          class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
        />
        <label for="li-classic" class="text-sm text-gray-700">Start with "Lorem ipsum…"</label>
      </div>

      <!-- Generate button -->
      <button
        id="li-generate"
        class="rounded-md bg-blue-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 transition-colors"
      >Generate</button>
    </div>
  </div>

  <!-- Output -->
  <div class="mt-6 relative">
    <textarea
      id="li-output"
      rows="14"
      readonly
      class="w-full rounded-lg border border-gray-300 bg-gray-50 p-4 text-base text-gray-700 shadow-sm resize-y focus:outline-none leading-relaxed"
    ></textarea>
    <button
      id="li-copy"
      class="absolute top-3 right-3 rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-blue-700 transition-colors"
    >Copy</button>
  </div>

  <!-- Explanation -->
  <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-gray-800 mb-3">About Lorem Ipsum</h2>
    <p class="text-sm text-gray-600 mb-3">
      Lorem ipsum dummy text has been the industry's standard placeholder text since the 1500s when an unknown printer scrambled a passage of Cicero's <em>De Finibus Bonorum et Malorum</em>. It remains widely used in graphic design, web development, and publishing to fill layouts without drawing attention to the content itself.
    </p>
    <ul class="space-y-2 text-sm text-gray-600">
      <li><span class="font-medium text-gray-700">Paragraphs</span> — 1–20 paragraphs, each 4–8 sentences long.</li>
      <li><span class="font-medium text-gray-700">Sentences</span> — 1–50 individual sentences.</li>
      <li><span class="font-medium text-gray-700">Words</span> — 10–500 words in a single block.</li>
      <li><span class="font-medium text-gray-700">"Lorem ipsum…" opener</span> — when checked, the first output always begins with the classic opening line.</li>
    </ul>
  </section>
</BaseLayout>

<script>
  // ── Word bank (200+ unique Latin-style words) ─────────────────────────────
  const WORDS: string[] = [
    'lorem','ipsum','dolor','sit','amet','consectetur','adipiscing','elit',
    'sed','do','eiusmod','tempor','incididunt','ut','labore','et','dolore',
    'magna','aliqua','enim','ad','minim','veniam','quis','nostrud','exercitation',
    'ullamco','laboris','nisi','aliquip','ex','ea','commodo','consequat','duis',
    'aute','irure','in','reprehenderit','voluptate','velit','esse','cillum',
    'eu','fugiat','nulla','pariatur','excepteur','sint','occaecat','cupidatat',
    'non','proident','sunt','culpa','qui','officia','deserunt','mollit','anim',
    'id','est','laborum','pellentesque','habitant','morbi','tristique','senectus',
    'netus','malesuada','fames','turpis','egestas','volutpat','neque','viverra',
    'justo','nec','ultrices','dui','sapien','eget','mi','proin','blandit',
    'aliquam','etiam','erat','velit','scelerisque','mauris','pellentesque',
    'pulvinar','cursus','metus','hendrerit','dolor','fusce','euismod','nisi',
    'porta','lorem','molestie','nisl','condimentum','id','venenatis','lectus',
    'magna','fringilla','urna','porttitor','rhoncus','dignissim','convallis',
    'aenean','pharetra','magna','ac','placerat','vestibulum','lectus','mauris',
    'ultrices','eros','in','cursus','turpis','massa','tincidunt','dui','ut',
    'ornare','quam','viverra','orci','sagittis','eu','volutpat','odio','facilisis',
    'gravida','neque','convallis','posuere','morbi','leo','urna','molestie','at',
    'elementum','eu','facilisis','sed','odio','morbi','quis','commodo','odio',
    'aenean','sed','adipiscing','diam','donec','adipiscing','tristique','risus',
    'nec','feugiat','nibh','sed','pulvinar','proin','nibh','nisl','condimentum',
    'id','venenatis','a','condimentum','vitae','sapien','pellentesque','habitant',
    'morbi','tristique','senectus','et','netus','malesuada','fames','ac','turpis',
    'egestas','integer','eget','aliquet','nibh','praesent','tristique','magna',
    'diam','maecenas','sed','enim','ut','sem','viverra','aliquet','eget','sit',
    'purus','in','mollis','nunc','sed','id','semper','risus','in','hendrerit',
    'gravida','rutrum','quisque','non','tellus','orci','ac','auctor','augue',
    'diam','quam','nulla','porttitor','massa','id','neque','aliquam','vestibulum',
    'morbi','enim','nunc','faucibus','pulvinar','elementum','integer','enim',
    'neque','volutpat','ac','tincidunt','vitae','semper','quis','lectus','nulla',
    'at','volutpat','diam','ut','venenatis','tellus','in','metus','vulputate',
    'eu','scelerisque','felis','imperdiet','proin','fermentum','leo','vel',
    'orci','porta','non','pulvinar','neque','laoreet','suspendisse','interdum',
    'consectetur','libero','id','faucibus','nisl','tincidunt','eget','nullam',
    'non','nisi','est','sit','amet','facilisis','magna','etiam','tempor',
    'orci','eu','lobortis','elementum','nibh','tellus','molestie','nunc',
    'non','blandit','massa','enim','nec','dui','nunc','mattis','enim','dui',
    'vivamus','arcu','felis','bibendum','ut','tristique','et','egestas',
    'aliquet','sagittis','id','consectetur','purus','ut','faucibus','pulvinar',
  ]

  const CLASSIC_OPENER = 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.'

  // ── Utilities ──────────────────────────────────────────────────────────────

  function rand(min: number, max: number): number {
    return Math.floor(Math.random() * (max - min + 1)) + min
  }

  function pick(arr: string[]): string {
    return arr[Math.floor(Math.random() * arr.length)]
  }

  function capitalize(s: string): string {
    return s.charAt(0).toUpperCase() + s.slice(1)
  }

  function makeSentence(): string {
    const len = rand(6, 18)
    const ws: string[] = []
    for (let i = 0; i < len; i++) ws.push(pick(WORDS))
    return capitalize(ws.join(' ')) + '.'
  }

  function makeParagraph(): string {
    const sentenceCount = rand(4, 8)
    const sentences: string[] = []
    for (let i = 0; i < sentenceCount; i++) sentences.push(makeSentence())
    return sentences.join(' ')
  }

  // ── Generate ───────────────────────────────────────────────────────────────

  function generate() {
    const mode    = (document.getElementById('li-mode')    as HTMLSelectElement).value
    const count   = parseInt((document.getElementById('li-count') as HTMLInputElement).value, 10)
    const classic = (document.getElementById('li-classic') as HTMLInputElement).checked

    let result = ''

    if (mode === 'paragraphs') {
      const n = Math.max(1, Math.min(20, count))
      const paragraphs: string[] = []
      for (let i = 0; i < n; i++) paragraphs.push(makeParagraph())
      if (classic) paragraphs[0] = CLASSIC_OPENER + ' ' + paragraphs[0]
      result = paragraphs.join('\n\n')

    } else if (mode === 'sentences') {
      const n = Math.max(1, Math.min(50, count))
      const sentences: string[] = []
      for (let i = 0; i < n; i++) sentences.push(makeSentence())
      if (classic) sentences[0] = CLASSIC_OPENER
      result = sentences.join(' ')

    } else {
      // words
      const n = Math.max(10, Math.min(500, count))
      const ws: string[] = []
      for (let i = 0; i < n; i++) ws.push(pick(WORDS))
      result = capitalize(ws.join(' ')) + '.'
      if (classic) {
        // Prepend classic words, trim total to n
        const classicWords = CLASSIC_OPENER.replace(/[.,]/g, '').split(' ')
        const remaining = ws.slice(classicWords.length)
        const combined = [...classicWords, ...remaining].slice(0, n)
        result = capitalize(combined.join(' ')) + '.'
      }
    }

    ;(document.getElementById('li-output') as HTMLTextAreaElement).value = result
  }

  // ── Clamp count on mode change ─────────────────────────────────────────────

  const modeEl  = document.getElementById('li-mode')  as HTMLSelectElement
  const countEl = document.getElementById('li-count') as HTMLInputElement

  const LIMITS: Record<string, [number, number, number]> = {
    paragraphs: [1, 20, 3],
    sentences:  [1, 50, 5],
    words:      [10, 500, 100],
  }

  modeEl.addEventListener('change', () => {
    const [min, max, def] = LIMITS[modeEl.value]
    countEl.min   = String(min)
    countEl.max   = String(max)
    countEl.value = String(def)
    generate()
  })

  countEl.addEventListener('change', () => {
    const [min, max] = LIMITS[modeEl.value]
    let v = parseInt(countEl.value, 10)
    if (isNaN(v)) v = min
    countEl.value = String(Math.max(min, Math.min(max, v)))
    generate()
  })

  document.getElementById('li-classic')!.addEventListener('change', generate)
  document.getElementById('li-generate')!.addEventListener('click', generate)

  // ── Copy ───────────────────────────────────────────────────────────────────

  const copyBtn = document.getElementById('li-copy') as HTMLButtonElement

  copyBtn.addEventListener('click', async () => {
    const text = (document.getElementById('li-output') as HTMLTextAreaElement).value
    if (!text) return
    try {
      await navigator.clipboard.writeText(text)
    } catch {
      const out = document.getElementById('li-output') as HTMLTextAreaElement
      out.select()
      document.execCommand('copy')
    }
    copyBtn.textContent = 'Copied!'
    copyBtn.classList.replace('bg-blue-600', 'bg-green-600')
    setTimeout(() => {
      copyBtn.textContent = 'Copy'
      copyBtn.classList.replace('bg-green-600', 'bg-blue-600')
    }, 1800)
  })

  // Auto-generate on load
  generate()
</script>
