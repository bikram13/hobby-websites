---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'readability-checker')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['Writing']}>
  <nav style="margin-bottom:1.5rem;">
    <a href="/" style="color:#b9c3ff; text-decoration:none; font-size:0.875rem;">← All Tools</a>
  </nav>
  <div style="margin-bottom:2.5rem;">
    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-0.025em; color:#e4e2e4; margin:0 0 0.75rem;">{tool.title}</h1>
    <p style="color:#c5c5d5; font-size:1.05rem; margin:0; max-width:36rem; line-height:1.6;">{tool.description}</p>
  </div>

  <textarea
    id="rc-input"
    rows="12"
    placeholder="Paste or type your text here…"
    class="w-full" style="border-radius:0.5rem; padding:1rem; font-size:1rem; resize:vertical; width:100%;"
  ></textarea>

  <p id="rc-hint" class="mt-4 text-sm italic" style="color:#8f909e;">Paste text above to analyze</p>

  <!-- Score cards -->
  <div class="mt-2 grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div class="glass-card" style="padding:1.5rem;">
      <p class="text-sm font-semibold uppercase tracking-wide mb-1" style="color:#8f909e;">Flesch Reading Ease</p>
      <p id="rc-ease-score" style="font-size:2.25rem; font-weight:700; color:#b9c3ff; margin:0.25rem 0;">—</p>
      <p id="rc-ease-label" class="mt-2 text-base" style="color:#c5c5d5;">Enter text above to see your score</p>
    </div>
    <div class="glass-card" style="padding:1.5rem;">
      <p class="text-sm font-semibold uppercase tracking-wide mb-1" style="color:#8f909e;">Flesch-Kincaid Grade Level</p>
      <p id="rc-grade-score" style="font-size:2.25rem; font-weight:700; color:#b9c3ff; margin:0.25rem 0;">—</p>
      <p id="rc-grade-label" class="mt-2 text-base" style="color:#c5c5d5;">Estimated US school grade</p>
    </div>
  </div>

  <!-- Supporting stats -->
  <div class="mt-4 grid grid-cols-3 gap-4">
    <div class="glass-card" style="padding:1rem; text-align:center; background:#1b1b1d;">
      <p id="rc-avg-words" style="font-size:1.5rem; font-weight:600; color:#e4e2e4; margin:0;">—</p>
      <p class="mt-1 text-xs" style="color:#8f909e;">Avg words / sentence</p>
    </div>
    <div class="glass-card" style="padding:1rem; text-align:center; background:#1b1b1d;">
      <p id="rc-avg-syllables" style="font-size:1.5rem; font-weight:600; color:#e4e2e4; margin:0;">—</p>
      <p class="mt-1 text-xs" style="color:#8f909e;">Avg syllables / word</p>
    </div>
    <div class="glass-card" style="padding:1rem; text-align:center; background:#1b1b1d;">
      <p id="rc-total-sentences" style="font-size:1.5rem; font-weight:600; color:#e4e2e4; margin:0;">—</p>
      <p class="mt-1 text-xs" style="color:#8f909e;">Sentences</p>
    </div>
  </div>

  <!-- Score legend -->
  <div class="glass-card mt-6 overflow-x-auto" style="padding:1.25rem;">
    <h2 class="text-sm font-semibold uppercase tracking-wide mb-3" style="color:#8f909e;">Reading Ease Score Reference</h2>
    <table class="w-full text-sm">
      <thead>
        <tr style="border-bottom:1px solid rgba(68,70,83,0.4); text-align:left; color:#8f909e;">
          <th class="pb-2 pr-4 font-medium">Score</th>
          <th class="pb-2 pr-4 font-medium">Grade</th>
          <th class="pb-2 font-medium">Description</th>
        </tr>
      </thead>
      <tbody style="color:#c5c5d5;">
        <tr style="border-bottom:1px solid rgba(68,70,83,0.2);"><td class="py-1.5 pr-4">90 – 100</td><td class="pr-4">5th grade</td><td>Very Easy</td></tr>
        <tr style="border-bottom:1px solid rgba(68,70,83,0.2);"><td class="py-1.5 pr-4">80 – 90</td><td class="pr-4">6th grade</td><td>Easy</td></tr>
        <tr style="border-bottom:1px solid rgba(68,70,83,0.2);"><td class="py-1.5 pr-4">70 – 80</td><td class="pr-4">7th grade</td><td>Fairly Easy</td></tr>
        <tr style="border-bottom:1px solid rgba(68,70,83,0.2);"><td class="py-1.5 pr-4">60 – 70</td><td class="pr-4">8th–9th grade</td><td>Standard</td></tr>
        <tr style="border-bottom:1px solid rgba(68,70,83,0.2);"><td class="py-1.5 pr-4">50 – 60</td><td class="pr-4">10th–12th grade</td><td>Fairly Difficult</td></tr>
        <tr style="border-bottom:1px solid rgba(68,70,83,0.2);"><td class="py-1.5 pr-4">30 – 50</td><td class="pr-4">College</td><td>Difficult</td></tr>
        <tr><td class="py-1.5 pr-4">0 – 30</td><td class="pr-4">College Graduate</td><td>Very Confusing</td></tr>
      </tbody>
    </table>
  </div>

  <section class="glass-card" style="margin-top:2.5rem; padding:1.5rem;">
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">About the Flesch formulas</h2>
    <ul class="space-y-2 text-sm" style="color:#c5c5d5;">
      <li><span style="color:#e4e2e4; font-weight:600;">Flesch Reading Ease</span> — scores 0–100; higher is easier. General web content targets 60–70. Academic writing often falls below 30.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">Flesch-Kincaid Grade Level</span> — maps the score to a US school grade. A score of 8 means an average 8th-grader can read it comfortably.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">Syllable counting</span> — counted by vowel groups (a, e, i, o, u) per word; each word has a minimum of 1 syllable. Results are approximate.</li>
    </ul>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('rc-input') as HTMLTextAreaElement
  const elHint            = document.getElementById('rc-hint')!

  const elEaseScore       = document.getElementById('rc-ease-score')!
  const elEaseLabel       = document.getElementById('rc-ease-label')!
  const elGradeScore      = document.getElementById('rc-grade-score')!
  const elGradeLabel      = document.getElementById('rc-grade-label')!
  const elAvgWords        = document.getElementById('rc-avg-words')!
  const elAvgSyllables    = document.getElementById('rc-avg-syllables')!
  const elTotalSentences  = document.getElementById('rc-total-sentences')!

  function countSyllables(word: string): number {
    const cleaned = word.toLowerCase().replace(/[^a-z]/g, '')
    if (cleaned.length === 0) return 0
    const groups = cleaned.match(/[aeiou]+/g)
    return groups ? Math.max(1, groups.length) : 1
  }

  function easeLabel(score: number): string {
    if (score >= 90) return '5th grade — Very Easy'
    if (score >= 80) return '6th grade — Easy'
    if (score >= 70) return '7th grade — Fairly Easy'
    if (score >= 60) return '8th-9th grade — Standard'
    if (score >= 50) return '10th-12th grade — Fairly Difficult'
    if (score >= 30) return 'College — Difficult'
    return 'College Graduate — Very Confusing'
  }

  function easeColor(score: number): string {
    if (score >= 70) return 'text-green-600'
    if (score >= 50) return 'text-amber-700'
    return 'text-red-600'
  }

  function update() {
    const text = input.value.trim()

    if (text === '') {
      elHint.style.display         = ''
      elEaseScore.textContent      = '—'
      elEaseScore.className        = 'text-4xl font-bold text-blue-600'
      elEaseLabel.textContent      = 'Paste text above to analyze'
      elGradeScore.textContent     = '—'
      elGradeLabel.textContent     = 'Estimated US school grade'
      elAvgWords.textContent       = '—'
      elAvgSyllables.textContent   = '—'
      elTotalSentences.textContent = '—'
      return
    }
    elHint.style.display = 'none'

    // Sentences
    const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0)
    const sentenceCount = sentences.length

    // Words
    const words = text.trim().split(/\s+/).filter(w => w.replace(/[^a-zA-Z]/g, '').length > 0)
    const wordCount = words.length

    if (wordCount === 0 || sentenceCount === 0) {
      elEaseScore.textContent  = '—'
      elGradeScore.textContent = '—'
      elAvgWords.textContent   = '—'
      elAvgSyllables.textContent = '—'
      elTotalSentences.textContent = sentenceCount.toString()
      return
    }

    // Syllables
    const totalSyllables = words.reduce((sum, w) => sum + countSyllables(w), 0)

    const avgWordsPerSentence    = wordCount / sentenceCount
    const avgSyllablesPerWord    = totalSyllables / wordCount

    // Flesch Reading Ease
    const ease = 206.835
      - (1.015  * avgWordsPerSentence)
      - (84.6   * avgSyllablesPerWord)
    const easeClamped = Math.min(100, Math.max(0, ease))

    // Flesch-Kincaid Grade Level
    const grade = (0.39 * avgWordsPerSentence)
      + (11.8  * avgSyllablesPerWord)
      - 15.59
    const gradeClamped = Math.max(0, grade)

    elEaseScore.textContent      = easeClamped.toFixed(1)
    elEaseScore.className        = `text-4xl font-bold ${easeColor(easeClamped)}`
    elEaseLabel.textContent      = easeLabel(easeClamped)

    elGradeScore.textContent     = gradeClamped.toFixed(1)
    elGradeLabel.textContent     = `Grade ${Math.round(gradeClamped)}`

    elAvgWords.textContent       = avgWordsPerSentence.toFixed(1)
    elAvgSyllables.textContent   = avgSyllablesPerWord.toFixed(2)
    elTotalSentences.textContent = sentenceCount.toString()
  }

  // localStorage persistence
  const LS_KEY = 'rc-input'
  const saved = localStorage.getItem(LS_KEY)
  if (saved) { input.value = saved; update() }
  input.addEventListener('input', () => {
    localStorage.setItem(LS_KEY, input.value)
    update()
  })
</script>
