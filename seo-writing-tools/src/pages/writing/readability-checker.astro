---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'readability-checker')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['Writing']}>
  <nav class="mb-6"><a href="/" class="text-blue-600 hover:text-blue-800 text-sm">← All Tools</a></nav>
  <h1 class="text-3xl font-bold text-gray-900 mb-3">{tool.title}</h1>
  <p class="text-gray-600 text-lg mb-6">{tool.description}</p>

  <textarea
    id="rc-input"
    rows="12"
    placeholder="Paste or type your text here…"
    class="w-full rounded-lg border border-gray-300 bg-white p-4 text-base text-gray-800 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200 resize-y"
  ></textarea>

  <!-- Score cards -->
  <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-1">Flesch Reading Ease</p>
      <p id="rc-ease-score" class="text-4xl font-bold text-blue-600">—</p>
      <p id="rc-ease-label" class="mt-2 text-base text-gray-700">Enter text above to see your score</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-1">Flesch-Kincaid Grade Level</p>
      <p id="rc-grade-score" class="text-4xl font-bold text-blue-600">—</p>
      <p id="rc-grade-label" class="mt-2 text-base text-gray-700">Estimated US school grade</p>
    </div>
  </div>

  <!-- Supporting stats -->
  <div class="mt-4 grid grid-cols-3 gap-4">
    <div class="rounded-lg border border-gray-100 bg-gray-50 p-4 text-center">
      <p id="rc-avg-words" class="text-2xl font-semibold text-gray-800">—</p>
      <p class="mt-1 text-xs text-gray-600">Avg words / sentence</p>
    </div>
    <div class="rounded-lg border border-gray-100 bg-gray-50 p-4 text-center">
      <p id="rc-avg-syllables" class="text-2xl font-semibold text-gray-800">—</p>
      <p class="mt-1 text-xs text-gray-600">Avg syllables / word</p>
    </div>
    <div class="rounded-lg border border-gray-100 bg-gray-50 p-4 text-center">
      <p id="rc-total-sentences" class="text-2xl font-semibold text-gray-800">—</p>
      <p class="mt-1 text-xs text-gray-600">Sentences</p>
    </div>
  </div>

  <!-- Score legend -->
  <div class="mt-6 rounded-lg border border-gray-200 bg-white p-5 shadow-sm overflow-x-auto">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-3">Reading Ease Score Reference</h2>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-100 text-left text-gray-500">
          <th class="pb-2 pr-4 font-medium">Score</th>
          <th class="pb-2 pr-4 font-medium">Grade</th>
          <th class="pb-2 font-medium">Description</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50 text-gray-700">
        <tr><td class="py-1.5 pr-4">90 – 100</td><td class="pr-4">5th grade</td><td>Very Easy</td></tr>
        <tr><td class="py-1.5 pr-4">80 – 90</td><td class="pr-4">6th grade</td><td>Easy</td></tr>
        <tr><td class="py-1.5 pr-4">70 – 80</td><td class="pr-4">7th grade</td><td>Fairly Easy</td></tr>
        <tr><td class="py-1.5 pr-4">60 – 70</td><td class="pr-4">8th–9th grade</td><td>Standard</td></tr>
        <tr><td class="py-1.5 pr-4">50 – 60</td><td class="pr-4">10th–12th grade</td><td>Fairly Difficult</td></tr>
        <tr><td class="py-1.5 pr-4">30 – 50</td><td class="pr-4">College</td><td>Difficult</td></tr>
        <tr><td class="py-1.5 pr-4">0 – 30</td><td class="pr-4">College Graduate</td><td>Very Confusing</td></tr>
      </tbody>
    </table>
  </div>

  <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-gray-800 mb-3">About the Flesch formulas</h2>
    <ul class="space-y-2 text-sm text-gray-600">
      <li><span class="font-medium text-gray-700">Flesch Reading Ease</span> — scores 0–100; higher is easier. General web content targets 60–70. Academic writing often falls below 30.</li>
      <li><span class="font-medium text-gray-700">Flesch-Kincaid Grade Level</span> — maps the score to a US school grade. A score of 8 means an average 8th-grader can read it comfortably.</li>
      <li><span class="font-medium text-gray-700">Syllable counting</span> — counted by vowel groups (a, e, i, o, u) per word; each word has a minimum of 1 syllable. Results are approximate.</li>
    </ul>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('rc-input') as HTMLTextAreaElement

  const elEaseScore       = document.getElementById('rc-ease-score')!
  const elEaseLabel       = document.getElementById('rc-ease-label')!
  const elGradeScore      = document.getElementById('rc-grade-score')!
  const elGradeLabel      = document.getElementById('rc-grade-label')!
  const elAvgWords        = document.getElementById('rc-avg-words')!
  const elAvgSyllables    = document.getElementById('rc-avg-syllables')!
  const elTotalSentences  = document.getElementById('rc-total-sentences')!

  function countSyllables(word: string): number {
    const cleaned = word.toLowerCase().replace(/[^a-z]/g, '')
    if (cleaned.length === 0) return 0
    const groups = cleaned.match(/[aeiou]+/g)
    return groups ? Math.max(1, groups.length) : 1
  }

  function easeLabel(score: number): string {
    if (score >= 90) return '5th grade — Very Easy'
    if (score >= 80) return '6th grade — Easy'
    if (score >= 70) return '7th grade — Fairly Easy'
    if (score >= 60) return '8th-9th grade — Standard'
    if (score >= 50) return '10th-12th grade — Fairly Difficult'
    if (score >= 30) return 'College — Difficult'
    return 'College Graduate — Very Confusing'
  }

  function easeColor(score: number): string {
    if (score >= 70) return 'text-green-600'
    if (score >= 50) return 'text-amber-700'
    return 'text-red-600'
  }

  function update() {
    const text = input.value.trim()

    if (text === '') {
      elEaseScore.textContent      = '—'
      elEaseScore.className        = 'text-4xl font-bold text-blue-600'
      elEaseLabel.textContent      = 'Enter text above to see your score'
      elGradeScore.textContent     = '—'
      elGradeLabel.textContent     = 'Estimated US school grade'
      elAvgWords.textContent       = '—'
      elAvgSyllables.textContent   = '—'
      elTotalSentences.textContent = '—'
      return
    }

    // Sentences
    const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0)
    const sentenceCount = sentences.length

    // Words
    const words = text.trim().split(/\s+/).filter(w => w.replace(/[^a-zA-Z]/g, '').length > 0)
    const wordCount = words.length

    if (wordCount === 0 || sentenceCount === 0) {
      elEaseScore.textContent  = '—'
      elGradeScore.textContent = '—'
      elAvgWords.textContent   = '—'
      elAvgSyllables.textContent = '—'
      elTotalSentences.textContent = sentenceCount.toString()
      return
    }

    // Syllables
    const totalSyllables = words.reduce((sum, w) => sum + countSyllables(w), 0)

    const avgWordsPerSentence    = wordCount / sentenceCount
    const avgSyllablesPerWord    = totalSyllables / wordCount

    // Flesch Reading Ease
    const ease = 206.835
      - (1.015  * avgWordsPerSentence)
      - (84.6   * avgSyllablesPerWord)
    const easeClamped = Math.min(100, Math.max(0, ease))

    // Flesch-Kincaid Grade Level
    const grade = (0.39 * avgWordsPerSentence)
      + (11.8  * avgSyllablesPerWord)
      - 15.59
    const gradeClamped = Math.max(0, grade)

    elEaseScore.textContent      = easeClamped.toFixed(1)
    elEaseScore.className        = `text-4xl font-bold ${easeColor(easeClamped)}`
    elEaseLabel.textContent      = easeLabel(easeClamped)

    elGradeScore.textContent     = gradeClamped.toFixed(1)
    elGradeLabel.textContent     = `Grade ${Math.round(gradeClamped)}`

    elAvgWords.textContent       = avgWordsPerSentence.toFixed(1)
    elAvgSyllables.textContent   = avgSyllablesPerWord.toFixed(2)
    elTotalSentences.textContent = sentenceCount.toString()
  }

  input.addEventListener('input', update)
</script>
