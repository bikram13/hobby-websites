---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'word-counter')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['Writing']}>
  <nav class="mb-6"><a href="/" class="text-blue-600 hover:text-blue-800 text-sm">← All Tools</a></nav>
  <h1 class="text-3xl font-bold text-gray-900 mb-3">{tool.title}</h1>
  <p class="text-gray-600 text-lg mb-6">{tool.description}</p>

  <textarea
    id="wc-input"
    rows="12"
    placeholder="Paste or type your text here…"
    class="w-full rounded-lg border border-gray-300 bg-white p-4 text-base text-gray-800 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200 resize-y"
  ></textarea>

  <p id="wc-hint" class="mt-4 text-sm text-gray-400 italic">Paste text above to analyze</p>
  <div class="mt-2 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
    <div class="rounded-lg border border-gray-200 bg-white p-4 text-center shadow-sm">
      <p id="wc-words" class="text-3xl font-bold text-blue-600">0</p>
      <p class="mt-1 text-sm text-gray-500">Words</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 text-center shadow-sm">
      <p id="wc-chars" class="text-3xl font-bold text-blue-600">0</p>
      <p class="mt-1 text-sm text-gray-500">Characters</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 text-center shadow-sm">
      <p id="wc-sentences" class="text-3xl font-bold text-blue-600">0</p>
      <p class="mt-1 text-sm text-gray-500">Sentences</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 text-center shadow-sm">
      <p id="wc-paragraphs" class="text-3xl font-bold text-blue-600">0</p>
      <p class="mt-1 text-sm text-gray-500">Paragraphs</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4 text-center shadow-sm col-span-2 sm:col-span-1">
      <p id="wc-reading" class="text-3xl font-bold text-blue-600">0 min</p>
      <p class="mt-1 text-sm text-gray-500">Reading Time</p>
    </div>
  </div>

  <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-gray-800 mb-3">How the stats are calculated</h2>
    <ul class="space-y-2 text-sm text-gray-600">
      <li><span class="font-medium text-gray-700">Words</span> — sequences of non-whitespace characters separated by spaces.</li>
      <li><span class="font-medium text-gray-700">Characters</span> — total characters including spaces and punctuation.</li>
      <li><span class="font-medium text-gray-700">Sentences</span> — split on <code class="rounded bg-gray-100 px-1">.</code> <code class="rounded bg-gray-100 px-1">!</code> <code class="rounded bg-gray-100 px-1">?</code> (non-empty segments only).</li>
      <li><span class="font-medium text-gray-700">Paragraphs</span> — blocks of text separated by one or more blank lines.</li>
      <li><span class="font-medium text-gray-700">Reading time</span> — assumes an average adult reading speed of 200 words per minute, rounded up to the nearest minute.</li>
    </ul>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('wc-input') as HTMLTextAreaElement
  const elWords      = document.getElementById('wc-words')!
  const elChars      = document.getElementById('wc-chars')!
  const elSentences  = document.getElementById('wc-sentences')!
  const elParagraphs = document.getElementById('wc-paragraphs')!
  const elReading    = document.getElementById('wc-reading')!
  const elHint       = document.getElementById('wc-hint')!

  const EMPTY_PLACEHOLDER = '—'
  const EMPTY_HINT = 'Paste text above to analyze'

  function update() {
    const text = input.value

    if (text.trim() === '') {
      elWords.textContent      = EMPTY_PLACEHOLDER
      elChars.textContent      = EMPTY_PLACEHOLDER
      elSentences.textContent  = EMPTY_PLACEHOLDER
      elParagraphs.textContent = EMPTY_PLACEHOLDER
      elReading.textContent    = EMPTY_PLACEHOLDER
      elHint.style.display     = ''
      return
    }
    elHint.style.display = 'none'

    // Words
    const words = text.trim().split(/\s+/).length

    // Characters (with spaces)
    const chars = text.length

    // Sentences — split on . ! ? keeping non-empty trimmed segments
    const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0).length

    // Paragraphs — split on one or more blank lines
    const paragraphs = text.split(/\n\s*\n/).filter(p => p.trim().length > 0).length

    // Reading time — 200 wpm, minimum 1 min if there's text
    const minutes = Math.ceil(words / 200)

    elWords.textContent      = words.toLocaleString()
    elChars.textContent      = chars.toLocaleString()
    elSentences.textContent  = sentences.toLocaleString()
    elParagraphs.textContent = paragraphs.toLocaleString()
    elReading.textContent    = `${minutes} min read`
  }

  // localStorage persistence
  const LS_KEY = 'wc-input'
  const saved = localStorage.getItem(LS_KEY)
  if (saved) { input.value = saved; update() }
  input.addEventListener('input', () => {
    localStorage.setItem(LS_KEY, input.value)
    update()
  })
</script>
