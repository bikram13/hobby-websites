---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'word-counter')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['Writing']}>
  <nav style="margin-bottom:1.5rem;">
    <a href="/" style="color:#b9c3ff; text-decoration:none; font-size:0.875rem;">← All Tools</a>
  </nav>
  <div style="margin-bottom:2.5rem;">
    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-0.025em; color:#e4e2e4; margin:0 0 0.75rem;">{tool.title}</h1>
    <p style="color:#c5c5d5; font-size:1.05rem; margin:0; max-width:36rem; line-height:1.6;">{tool.description}</p>
  </div>

  <textarea
    id="wc-input"
    rows="12"
    placeholder="Paste or type your text here…"
    class="w-full" style="border-radius:0.5rem; padding:1rem; font-size:1rem; resize:vertical; width:100%;"
  ></textarea>

  <p id="wc-hint" class="mt-4 text-sm italic" style="color:#8f909e;">Paste text above to analyze</p>
  <div class="mt-2 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
    <div class="glass-card" style="padding:1rem; text-align:center;">
      <p id="wc-words" style="font-size:1.875rem; font-weight:700; color:#b9c3ff; margin:0;">0</p>
      <p class="mt-1 text-sm" style="color:#8f909e; margin:0.25rem 0 0;">Words</p>
    </div>
    <div class="glass-card" style="padding:1rem; text-align:center;">
      <p id="wc-chars" style="font-size:1.875rem; font-weight:700; color:#b9c3ff; margin:0;">0</p>
      <p class="mt-1 text-sm" style="color:#8f909e; margin:0.25rem 0 0;">Characters</p>
    </div>
    <div class="glass-card" style="padding:1rem; text-align:center;">
      <p id="wc-sentences" style="font-size:1.875rem; font-weight:700; color:#b9c3ff; margin:0;">0</p>
      <p class="mt-1 text-sm" style="color:#8f909e; margin:0.25rem 0 0;">Sentences</p>
    </div>
    <div class="glass-card" style="padding:1rem; text-align:center;">
      <p id="wc-paragraphs" style="font-size:1.875rem; font-weight:700; color:#b9c3ff; margin:0;">0</p>
      <p class="mt-1 text-sm" style="color:#8f909e; margin:0.25rem 0 0;">Paragraphs</p>
    </div>
    <div class="glass-card col-span-2 sm:col-span-1" style="padding:1rem; text-align:center;">
      <p id="wc-reading" style="font-size:1.875rem; font-weight:700; color:#b9c3ff; margin:0;">0 min</p>
      <p class="mt-1 text-sm" style="color:#8f909e; margin:0.25rem 0 0;">Reading Time</p>
    </div>
  </div>

  <section class="glass-card" style="margin-top:2.5rem; padding:1.5rem;">
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">How the stats are calculated</h2>
    <ul class="space-y-2 text-sm" style="color:#c5c5d5;">
      <li><span style="color:#e4e2e4; font-weight:600;">Words</span> — sequences of non-whitespace characters separated by spaces.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">Characters</span> — total characters including spaces and punctuation.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">Sentences</span> — split on <code style="background:rgba(185,195,255,0.1); border-radius:0.25rem; padding:0.1rem 0.3rem; color:#b9c3ff;">.</code> <code style="background:rgba(185,195,255,0.1); border-radius:0.25rem; padding:0.1rem 0.3rem; color:#b9c3ff;">!</code> <code style="background:rgba(185,195,255,0.1); border-radius:0.25rem; padding:0.1rem 0.3rem; color:#b9c3ff;">?</code> (non-empty segments only).</li>
      <li><span style="color:#e4e2e4; font-weight:600;">Paragraphs</span> — blocks of text separated by one or more blank lines.</li>
      <li><span style="color:#e4e2e4; font-weight:600;">Reading time</span> — assumes an average adult reading speed of 200 words per minute, rounded up to the nearest minute.</li>
    </ul>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('wc-input') as HTMLTextAreaElement
  const elWords      = document.getElementById('wc-words')!
  const elChars      = document.getElementById('wc-chars')!
  const elSentences  = document.getElementById('wc-sentences')!
  const elParagraphs = document.getElementById('wc-paragraphs')!
  const elReading    = document.getElementById('wc-reading')!
  const elHint       = document.getElementById('wc-hint')!

  const EMPTY_PLACEHOLDER = '—'
  const EMPTY_HINT = 'Paste text above to analyze'

  function update() {
    const text = input.value

    if (text.trim() === '') {
      elWords.textContent      = EMPTY_PLACEHOLDER
      elChars.textContent      = EMPTY_PLACEHOLDER
      elSentences.textContent  = EMPTY_PLACEHOLDER
      elParagraphs.textContent = EMPTY_PLACEHOLDER
      elReading.textContent    = EMPTY_PLACEHOLDER
      elHint.style.display     = ''
      return
    }
    elHint.style.display = 'none'

    // Words
    const words = text.trim().split(/\s+/).length

    // Characters (with spaces)
    const chars = text.length

    // Sentences — split on . ! ? keeping non-empty trimmed segments
    const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0).length

    // Paragraphs — split on one or more blank lines
    const paragraphs = text.split(/\n\s*\n/).filter(p => p.trim().length > 0).length

    // Reading time — 200 wpm, minimum 1 min if there's text
    const minutes = Math.ceil(words / 200)

    elWords.textContent      = words.toLocaleString()
    elChars.textContent      = chars.toLocaleString()
    elSentences.textContent  = sentences.toLocaleString()
    elParagraphs.textContent = paragraphs.toLocaleString()
    elReading.textContent    = `${minutes} min read`
  }

  // localStorage persistence
  const LS_KEY = 'wc-input'
  const saved = localStorage.getItem(LS_KEY)
  if (saved) { input.value = saved; update() }
  input.addEventListener('input', () => {
    localStorage.setItem(LS_KEY, input.value)
    update()
  })
</script>
