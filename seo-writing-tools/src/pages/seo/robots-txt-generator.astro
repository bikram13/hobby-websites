---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'

const tool = tools.find(t => t.slug === 'robots-txt-generator')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
---
<BaseLayout title={title} description={description}>
  <nav class="mb-6"><a href="/" class="text-blue-600 hover:text-blue-800 text-sm">← All Tools</a></nav>
  <h1 class="text-3xl font-bold text-gray-900 mb-3">{tool.title}</h1>
  <p class="text-gray-600 text-lg mb-6">{tool.description}</p>

  <div class="grid gap-6 lg:grid-cols-2">
    <!-- Rule Builder -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Sitemap URL <span class="font-normal text-gray-400">(optional)</span></label>
        <input id="rb-sitemap" type="url" placeholder="https://yoursite.com/sitemap.xml"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-800 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200" />
      </div>

      <div id="rb-rules" class="space-y-3">
        <!-- Rules added dynamically -->
      </div>

      <button id="rb-add" class="text-sm text-blue-600 hover:text-blue-800 font-medium">+ Add rule</button>
    </div>

    <!-- Output -->
    <div class="space-y-3">
      <!-- Warning banner -->
      <div id="rb-warning" class="hidden rounded-lg border border-red-300 bg-red-50 p-4">
        <p class="text-sm font-semibold text-red-700">Warning: Disallow: / blocks ALL crawlers</p>
        <p class="text-sm text-red-600 mt-1">This will prevent search engines from indexing your entire site. Only use this if you intentionally want the site de-indexed.</p>
      </div>

      <div class="flex items-center justify-between">
        <h2 class="text-sm font-semibold text-gray-600 uppercase tracking-wide">Generated robots.txt</h2>
        <button id="rb-copy" class="rounded-md border border-gray-300 bg-white px-3 py-1 text-xs text-gray-600 hover:border-blue-400 hover:text-blue-600">Copy</button>
      </div>
      <pre id="rb-output" class="rounded-lg bg-gray-900 text-green-400 text-sm p-4 overflow-x-auto whitespace-pre-wrap min-h-[160px] font-mono"></pre>
    </div>
  </div>

  <script>
    const rulesContainer = document.getElementById('rb-rules')
    const addBtn = document.getElementById('rb-add')
    const sitemapEl = document.getElementById('rb-sitemap')
    const output = document.getElementById('rb-output')
    const copyBtn = document.getElementById('rb-copy')
    const warning = document.getElementById('rb-warning')

    let ruleCount = 0

    function addRule(userAgent = '*', directive = 'Disallow', path = '') {
      const id = ++ruleCount
      const div = document.createElement('div')
      div.className = 'grid grid-cols-[1fr_1fr_1fr_auto] gap-2 items-center'
      div.id = `rule-${id}`
      div.innerHTML = `
        <select class="rb-agent rounded border border-gray-300 px-2 py-1.5 text-sm bg-white focus:outline-none focus:border-blue-400">
          <option value="*"${userAgent==='*'?' selected':''}>All bots (*)</option>
          <option value="Googlebot"${userAgent==='Googlebot'?' selected':''}>Googlebot</option>
          <option value="Bingbot"${userAgent==='Bingbot'?' selected':''}>Bingbot</option>
          <option value="GPTBot"${userAgent==='GPTBot'?' selected':''}>GPTBot (OpenAI)</option>
          <option value="Claude-Web"${userAgent==='Claude-Web'?' selected':''}>Claude-Web</option>
        </select>
        <select class="rb-directive rounded border border-gray-300 px-2 py-1.5 text-sm bg-white focus:outline-none focus:border-blue-400">
          <option value="Disallow"${directive==='Disallow'?' selected':''}>Disallow</option>
          <option value="Allow"${directive==='Allow'?' selected':''}>Allow</option>
        </select>
        <input type="text" class="rb-path rounded border border-gray-300 px-2 py-1.5 text-sm focus:outline-none focus:border-blue-400" placeholder="/path/" value="${path}" />
        <button class="rb-remove text-gray-400 hover:text-red-500 text-lg leading-none px-1">×</button>
      `
      div.querySelector('.rb-remove').addEventListener('click', () => { div.remove(); generate() })
      div.querySelectorAll('select, input').forEach(el => el.addEventListener('input', generate))
      rulesContainer.appendChild(div)
      generate()
    }

    function generate() {
      const groups = {}
      document.querySelectorAll('#rb-rules > div').forEach(div => {
        const agent = div.querySelector('.rb-agent').value
        const directive = div.querySelector('.rb-directive').value
        const path = div.querySelector('.rb-path').value.trim() || '/'
        if (!groups[agent]) groups[agent] = []
        groups[agent].push({ directive, path })
      })

      let hasDisallowAll = false
      const lines = []
      for (const [agent, rules] of Object.entries(groups)) {
        lines.push(`User-agent: ${agent}`)
        for (const { directive, path } of rules) {
          lines.push(`${directive}: ${path}`)
          if (directive === 'Disallow' && path === '/') hasDisallowAll = true
        }
        lines.push('')
      }

      const sitemap = sitemapEl.value.trim()
      if (sitemap) lines.push(`Sitemap: ${sitemap}`)

      output.textContent = lines.join('\n').trim()
      warning.classList.toggle('hidden', !hasDisallowAll)
    }

    addBtn.addEventListener('click', () => addRule())
    sitemapEl.addEventListener('input', generate)
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(output.textContent).then(() => {
        copyBtn.textContent = 'Copied!'
        setTimeout(() => copyBtn.textContent = 'Copy', 1500)
      })
    })

    // Start with one default rule
    addRule('*', 'Allow', '/')
  </script>

  <section class="mt-12 border-t border-gray-200 pt-8 text-gray-600 text-sm leading-relaxed space-y-4">
    <h2 class="text-xl font-semibold text-gray-800">How to use the Robots.txt Generator</h2>
    <p>Add rules using the "Add rule" button. Choose which bot the rule applies to, whether to Allow or Disallow, and the path. The output updates instantly. Copy and save the result as <code class="bg-gray-100 px-1 rounded">robots.txt</code> in your site's root.</p>
    <h2 class="text-xl font-semibold text-gray-800">What is robots.txt?</h2>
    <p>The robots.txt file tells search engine crawlers which pages they can and can't access on your site. It's placed at the root of your domain (e.g. <code class="bg-gray-100 px-1 rounded">https://yoursite.com/robots.txt</code>). Note: robots.txt is advisory — malicious bots may ignore it. It does not provide security, only crawl guidance.</p>
    <p class="text-red-600 font-medium">Never use <code class="bg-red-50 px-1 rounded">Disallow: /</code> on a production site unless you want it completely removed from search engines.</p>
  </section>
</BaseLayout>
