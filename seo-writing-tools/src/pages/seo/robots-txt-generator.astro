---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'robots-txt-generator')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['SEO']}>
  <nav style="margin-bottom:1.5rem;">
    <a href="/" style="color:#b9c3ff; text-decoration:none; font-size:0.875rem;">← All Tools</a>
  </nav>
  <div style="margin-bottom:2.5rem;">
    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-0.025em; color:#e4e2e4; margin:0 0 0.75rem;">{tool.title}</h1>
    <p style="color:#c5c5d5; font-size:1.05rem; margin:0; max-width:36rem; line-height:1.6;">{tool.description}</p>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <!-- Rule Builder -->
    <div class="glass-card space-y-5" style="padding:1.5rem;">
      <div>
        <label class="block text-sm font-medium mb-1" style="color:#c5c5d5;">Sitemap URL <span class="font-normal" style="color:#8f909e;">(optional)</span></label>
        <input id="rb-sitemap" type="url" placeholder="https://yoursite.com/sitemap.xml"
          class="w-full" style="border-radius:0.5rem; padding:0.5rem 0.75rem; font-size:0.875rem; width:100%;" />
      </div>

      <div id="rb-rules" class="space-y-3">
        <!-- Rules added dynamically -->
      </div>

      <button id="rb-add" class="text-sm font-medium" style="color:#b9c3ff; background:none; border:none; cursor:pointer; padding:0;">+ Add rule</button>
    </div>

    <!-- Output -->
    <div class="space-y-3">
      <!-- Warning banner -->
      <div id="rb-warning" class="hidden rounded-lg p-4" style="border:2px solid #f87171; background:rgba(248,113,113,0.08);" role="alert" aria-live="assertive">
        <div class="flex items-start gap-2">
          <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true" style="color:#f87171;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
          </svg>
          <div>
            <p class="text-sm font-bold" style="color:#f87171;">WARNING: Disallow: / will block ALL crawlers</p>
            <p class="text-sm mt-1" style="color:#fca5a5;">This will prevent search engines from indexing your entire site. Only use this if you intentionally want the site de-indexed.</p>
          </div>
        </div>
      </div>
      <style>
        @keyframes rb-flash {
          0%, 100% { background-color: rgba(248,113,113,0.08); }
          25%, 75% { background-color: rgba(248,113,113,0.15); }
          50% { background-color: rgba(248,113,113,0.22); }
        }
        #rb-warning.rb-flash-anim { animation: rb-flash 0.6s ease-in-out; }
      </style>

      <div class="flex items-center justify-between">
        <h2 class="text-sm font-semibold uppercase tracking-wide" style="color:#8f909e;">Generated robots.txt</h2>
        <button id="rb-copy" class="rounded-md px-3 py-1 text-xs" style="background:rgba(53,52,55,0.8); color:#c5c5d5; border:1px solid rgba(68,70,83,0.4); cursor:pointer;">Copy</button>
      </div>
      <pre id="rb-output" class="rounded-lg text-sm p-4 overflow-x-auto whitespace-pre-wrap min-h-[160px] font-mono" style="background:#0d0d0f; color:#4edea3; border:1px solid rgba(68,70,83,0.4);"></pre>
    </div>
  </div>

  <script>
    const rulesContainer = document.getElementById('rb-rules')
    const addBtn = document.getElementById('rb-add')
    const sitemapEl = document.getElementById('rb-sitemap')
    const output = document.getElementById('rb-output')
    const copyBtn = document.getElementById('rb-copy')
    const warning = document.getElementById('rb-warning')

    let ruleCount = 0

    function addRule(userAgent = '*', directive = 'Disallow', path = '') {
      const id = ++ruleCount
      const div = document.createElement('div')
      div.className = 'grid grid-cols-[1fr_1fr_1fr_auto] gap-2 items-center'
      div.id = `rule-${id}`
      div.innerHTML = `
        <select class="rb-agent" style="border-radius:0.375rem; padding:0.375rem 0.5rem; font-size:0.875rem;">
          <option value="*"${userAgent==='*'?' selected':''}>All bots (*)</option>
          <option value="Googlebot"${userAgent==='Googlebot'?' selected':''}>Googlebot</option>
          <option value="Bingbot"${userAgent==='Bingbot'?' selected':''}>Bingbot</option>
          <option value="GPTBot"${userAgent==='GPTBot'?' selected':''}>GPTBot (OpenAI)</option>
          <option value="Claude-Web"${userAgent==='Claude-Web'?' selected':''}>Claude-Web</option>
        </select>
        <select class="rb-directive" style="border-radius:0.375rem; padding:0.375rem 0.5rem; font-size:0.875rem;">
          <option value="Disallow"${directive==='Disallow'?' selected':''}>Disallow</option>
          <option value="Allow"${directive==='Allow'?' selected':''}>Allow</option>
        </select>
        <input type="text" class="rb-path" style="border-radius:0.375rem; padding:0.375rem 0.5rem; font-size:0.875rem;" placeholder="/path/" value="${path}" />
        <button class="rb-remove" style="color:#8f909e; background:none; border:none; cursor:pointer; font-size:1.25rem; line-height:1; padding:0 0.25rem;">×</button>
      `
      div.querySelector('.rb-remove').addEventListener('click', () => { div.remove(); generate() })
      div.querySelectorAll('select, input').forEach(el => el.addEventListener('input', generate))
      rulesContainer.appendChild(div)
      generate()
    }

    function generate() {
      const groups = {}
      document.querySelectorAll('#rb-rules > div').forEach(div => {
        const agent = div.querySelector('.rb-agent').value
        const directive = div.querySelector('.rb-directive').value
        const path = div.querySelector('.rb-path').value.trim() || '/'
        if (!groups[agent]) groups[agent] = []
        groups[agent].push({ directive, path })
      })

      let hasDisallowAll = false
      const lines = []
      for (const [agent, rules] of Object.entries(groups)) {
        lines.push(`User-agent: ${agent}`)
        for (const { directive, path } of rules) {
          lines.push(`${directive}: ${path}`)
          if (directive === 'Disallow' && path === '/') hasDisallowAll = true
        }
        lines.push('')
      }

      const sitemap = sitemapEl.value.trim()
      if (sitemap) lines.push(`Sitemap: ${sitemap}`)

      output.textContent = lines.join('\n').trim()
      const wasHidden = warning.classList.contains('hidden')
      warning.classList.toggle('hidden', !hasDisallowAll)
      if (hasDisallowAll && wasHidden) {
        warning.classList.remove('rb-flash-anim')
        // Force reflow to restart animation
        void (warning as HTMLElement).offsetWidth
        warning.classList.add('rb-flash-anim')
        warning.addEventListener('animationend', () => warning.classList.remove('rb-flash-anim'), { once: true })
      }
    }

    addBtn.addEventListener('click', () => addRule())
    sitemapEl.addEventListener('input', generate)
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(output.textContent).then(() => {
        copyBtn.textContent = 'Copied!'
        setTimeout(() => copyBtn.textContent = 'Copy', 1500)
      })
    })

    // Start with one default rule
    addRule('*', 'Allow', '/')
  </script>

  <section class="glass-card" style="margin-top:2.5rem; padding:1.5rem;">
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">How to use the Robots.txt Generator</h2>
    <p style="color:#c5c5d5; margin:0 0 1rem;">Add rules using the "Add rule" button. Choose which bot the rule applies to, whether to Allow or Disallow, and the path. The output updates instantly. Copy and save the result as <code style="background:rgba(185,195,255,0.1); border-radius:0.25rem; padding:0.1rem 0.3rem; color:#b9c3ff;">robots.txt</code> in your site's root.</p>
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">What is robots.txt?</h2>
    <p style="color:#c5c5d5; margin:0 0 0.75rem;">The robots.txt file tells search engine crawlers which pages they can and can't access on your site. It's placed at the root of your domain (e.g. <code style="background:rgba(185,195,255,0.1); border-radius:0.25rem; padding:0.1rem 0.3rem; color:#b9c3ff;">https://yoursite.com/robots.txt</code>). Note: robots.txt is advisory — malicious bots may ignore it. It does not provide security, only crawl guidance.</p>
    <p style="color:#f87171; font-weight:500; margin:0;">Never use <code style="background:rgba(248,113,113,0.1); border-radius:0.25rem; padding:0.1rem 0.3rem;">Disallow: /</code> on a production site unless you want it completely removed from search engines.</p>
  </section>
</BaseLayout>
