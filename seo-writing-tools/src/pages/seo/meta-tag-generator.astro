---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'meta-tag-generator')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['SEO']}>
  <nav style="margin-bottom:1.5rem;">
    <a href="/" style="color:#b9c3ff; text-decoration:none; font-size:0.875rem;">← All Tools</a>
  </nav>
  <div style="margin-bottom:2.5rem;">
    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-0.025em; color:#e4e2e4; margin:0 0 0.75rem;">{tool.title}</h1>
    <p style="color:#c5c5d5; font-size:1.05rem; margin:0; max-width:36rem; line-height:1.6;">{tool.description}</p>
  </div>

  <div class="glass-card space-y-4" style="padding:1.5rem;">
    <div>
      <label class="block text-sm font-medium mb-1" style="color:#c5c5d5;">
        Page Title <span id="mt-title-count" class="font-normal" style="color:#8f909e;">0 / 60</span>
      </label>
      <input
        id="mt-title"
        type="text"
        maxlength="100"
        placeholder="Best Running Shoes for Beginners in 2025"
        class="w-full" style="border-radius:0.5rem; padding:0.5rem 0.75rem; font-size:1rem; width:100%;"
      />
    </div>
    <div>
      <label class="block text-sm font-medium mb-1" style="color:#c5c5d5;">
        Meta Description <span id="mt-desc-count" class="font-normal" style="color:#8f909e;">0 / 160</span>
      </label>
      <textarea
        id="mt-desc"
        rows="3"
        maxlength="300"
        placeholder="Discover the top-rated running shoes for beginners. Compare cushioning, fit, and durability to find your perfect first pair."
        class="w-full" style="border-radius:0.5rem; padding:0.5rem 0.75rem; font-size:1rem; resize:none; width:100%;"
      ></textarea>
    </div>
  </div>

  <div class="mt-6">
    <h2 class="text-sm font-semibold uppercase tracking-wide mb-3" style="color:#8f909e;">SERP Preview</h2>
    <div id="mt-serp" class="glass-card max-w-2xl" style="padding:1.25rem; font-family:Arial,sans-serif;">
      <div id="mt-serp-title" class="text-[18px] truncate cursor-pointer" style="color:#b9c3ff; font-size:1.125rem;">Your page title will appear here</div>
      <div class="text-[13px] my-1" style="color:#4edea3; font-size:0.8rem;">https://yoursite.com/page/</div>
      <div id="mt-serp-desc" class="text-[13px] leading-snug" style="color:#c5c5d5;font-size:0.8rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">Your meta description will appear here. Make it compelling and under 160 characters.</div>
    </div>
  </div>

  <div class="mt-6">
    <h2 class="text-sm font-semibold uppercase tracking-wide mb-3" style="color:#8f909e;">Generated Tags</h2>
    <div class="relative">
      <pre id="mt-output" class="rounded-lg text-sm p-4 overflow-x-auto whitespace-pre-wrap min-h-[80px]" style="background:#0d0d0f; color:#4edea3; border:1px solid rgba(68,70,83,0.4);"></pre>
      <button id="mt-copy" class="absolute top-2 right-2 rounded-md px-3 py-1 text-xs" style="background:rgba(53,52,55,0.8); color:#c5c5d5; border:1px solid rgba(68,70,83,0.4); cursor:pointer;">Copy</button>
    </div>
  </div>

  <script>
    const titleEl = document.getElementById('mt-title')
    const descEl = document.getElementById('mt-desc')
    const titleCount = document.getElementById('mt-title-count')
    const descCount = document.getElementById('mt-desc-count')
    const serpTitle = document.getElementById('mt-serp-title')
    const serpDesc = document.getElementById('mt-serp-desc')
    const output = document.getElementById('mt-output')
    const copyBtn = document.getElementById('mt-copy')

    function update() {
      const t = titleEl.value
      const d = descEl.value

      titleCount.textContent = `${t.length} / 60`
      titleCount.className = `font-normal ${t.length > 60 ? 'text-red-500' : 'text-gray-500'}`
      descCount.textContent = `${d.length} / 160`
      descCount.className = `font-normal ${d.length > 160 ? 'text-red-500' : 'text-gray-500'}`

      serpTitle.textContent = t || 'Your page title will appear here'
      serpDesc.textContent = d || 'Your meta description will appear here.'

      const esc = s => s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      output.textContent = t || d
        ? `<title>${esc(t)}</title>\n<meta name="description" content="${esc(d)}">\n<meta property="og:title" content="${esc(t)}">\n<meta property="og:description" content="${esc(d)}">`
        : ''
    }

    titleEl.addEventListener('input', update)
    descEl.addEventListener('input', update)

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(output.textContent).then(() => {
        copyBtn.textContent = 'Copied!'
        setTimeout(() => copyBtn.textContent = 'Copy', 1500)
      })
    })

    update()
  </script>

  <section class="glass-card" style="margin-top:2.5rem; padding:1.5rem;">
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">How to use the Meta Tag Generator</h2>
    <p style="color:#c5c5d5; margin:0 0 1rem;">Enter your page title and meta description in the fields above. The live SERP preview shows exactly how your result will appear in Google search. Copy the generated HTML tags and paste them into the <code style="background:rgba(185,195,255,0.1); border-radius:0.25rem; padding:0.1rem 0.3rem; color:#b9c3ff;">&lt;head&gt;</code> of your page.</p>
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">Title and description best practices</h2>
    <p style="color:#c5c5d5; margin:0 0 0.75rem;"><strong style="color:#e4e2e4;">Title:</strong> Keep it under 60 characters. Include your primary keyword near the start. Make it descriptive and click-worthy.</p>
    <p style="color:#c5c5d5; margin:0;"><strong style="color:#e4e2e4;">Description:</strong> Aim for 150–160 characters. Summarize the page value and include a call to action. Google may rewrite it, but a good description improves click-through rates.</p>
  </section>
</BaseLayout>
