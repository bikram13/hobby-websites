---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'

const tool = tools.find(t => t.slug === 'meta-tag-generator')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
---
<BaseLayout title={title} description={description}>
  <nav class="mb-6"><a href="/" class="text-blue-600 hover:text-blue-800 text-sm">← All Tools</a></nav>
  <h1 class="text-3xl font-bold text-gray-900 mb-3">{tool.title}</h1>
  <p class="text-gray-600 text-lg mb-6">{tool.description}</p>

  <div class="space-y-4 bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        Page Title <span id="mt-title-count" class="font-normal text-gray-400">0 / 60</span>
      </label>
      <input
        id="mt-title"
        type="text"
        maxlength="100"
        placeholder="Best Running Shoes for Beginners in 2025"
        class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-base text-gray-800 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
      />
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        Meta Description <span id="mt-desc-count" class="font-normal text-gray-400">0 / 160</span>
      </label>
      <textarea
        id="mt-desc"
        rows="3"
        maxlength="300"
        placeholder="Discover the top-rated running shoes for beginners. Compare cushioning, fit, and durability to find your perfect first pair."
        class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-base text-gray-800 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200 resize-none"
      ></textarea>
    </div>
  </div>

  <div class="mt-6">
    <h2 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-3">SERP Preview</h2>
    <div id="mt-serp" class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm max-w-2xl" style="font-family:Arial,sans-serif">
      <div id="mt-serp-title" class="text-[18px] truncate cursor-pointer" style="color:#1a0dab">Your page title will appear here</div>
      <div class="text-[13px] my-1" style="color:#006621">https://yoursite.com/page/</div>
      <div id="mt-serp-desc" class="text-[13px] leading-snug" style="color:#545454;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">Your meta description will appear here. Make it compelling and under 160 characters.</div>
    </div>
  </div>

  <div class="mt-6">
    <h2 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-3">Generated Tags</h2>
    <div class="relative">
      <pre id="mt-output" class="rounded-lg bg-gray-900 text-green-400 text-sm p-4 overflow-x-auto whitespace-pre-wrap min-h-[80px]"></pre>
      <button id="mt-copy" class="absolute top-2 right-2 rounded-md bg-gray-700 px-3 py-1 text-xs text-gray-200 hover:bg-gray-600">Copy</button>
    </div>
  </div>

  <script>
    const titleEl = document.getElementById('mt-title')
    const descEl = document.getElementById('mt-desc')
    const titleCount = document.getElementById('mt-title-count')
    const descCount = document.getElementById('mt-desc-count')
    const serpTitle = document.getElementById('mt-serp-title')
    const serpDesc = document.getElementById('mt-serp-desc')
    const output = document.getElementById('mt-output')
    const copyBtn = document.getElementById('mt-copy')

    function update() {
      const t = titleEl.value
      const d = descEl.value

      titleCount.textContent = `${t.length} / 60`
      titleCount.className = `font-normal ${t.length > 60 ? 'text-red-500' : 'text-gray-400'}`
      descCount.textContent = `${d.length} / 160`
      descCount.className = `font-normal ${d.length > 160 ? 'text-red-500' : 'text-gray-400'}`

      serpTitle.textContent = t || 'Your page title will appear here'
      serpDesc.textContent = d || 'Your meta description will appear here.'

      const esc = s => s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      output.textContent = t || d
        ? `<title>${esc(t)}</title>\n<meta name="description" content="${esc(d)}">\n<meta property="og:title" content="${esc(t)}">\n<meta property="og:description" content="${esc(d)}">`
        : ''
    }

    titleEl.addEventListener('input', update)
    descEl.addEventListener('input', update)

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(output.textContent).then(() => {
        copyBtn.textContent = 'Copied!'
        setTimeout(() => copyBtn.textContent = 'Copy', 1500)
      })
    })

    update()
  </script>

  <section class="mt-12 border-t border-gray-200 pt-8 text-gray-600 text-sm leading-relaxed space-y-4">
    <h2 class="text-xl font-semibold text-gray-800">How to use the Meta Tag Generator</h2>
    <p>Enter your page title and meta description in the fields above. The live SERP preview shows exactly how your result will appear in Google search. Copy the generated HTML tags and paste them into the <code class="bg-gray-100 px-1 rounded">&lt;head&gt;</code> of your page.</p>
    <h2 class="text-xl font-semibold text-gray-800">Title and description best practices</h2>
    <p><strong>Title:</strong> Keep it under 60 characters. Include your primary keyword near the start. Make it descriptive and click-worthy.</p>
    <p><strong>Description:</strong> Aim for 150–160 characters. Summarize the page value and include a call to action. Google may rewrite it, but a good description improves click-through rates.</p>
  </section>
</BaseLayout>
