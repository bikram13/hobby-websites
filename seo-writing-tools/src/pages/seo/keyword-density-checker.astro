---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'keyword-density-checker')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['SEO']}>
  <nav style="margin-bottom:1.5rem;">
    <a href="/" style="color:#b9c3ff; text-decoration:none; font-size:0.875rem;">← All Tools</a>
  </nav>
  <div style="margin-bottom:2.5rem;">
    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-0.025em; color:#e4e2e4; margin:0 0 0.75rem;">{tool.title}</h1>
    <p style="color:#c5c5d5; font-size:1.05rem; margin:0; max-width:36rem; line-height:1.6;">{tool.description}</p>
  </div>

  <textarea
    id="kd-input"
    rows="10"
    placeholder="Paste your content here to analyze keyword frequency…"
    class="w-full" style="border-radius:0.5rem; padding:1rem; font-size:1rem; resize:vertical; width:100%;"
  ></textarea>

  <div id="kd-stats" class="mt-3 text-sm" style="color:#8f909e;"></div>

  <div id="kd-results" class="mt-6 hidden">
    <h2 class="text-lg font-semibold mb-3" style="color:#e4e2e4;">Top Keywords</h2>
    <div class="overflow-x-auto rounded-lg" style="border:1px solid rgba(68,70,83,0.4);">
      <table class="w-full text-sm text-left">
        <thead style="background:#1b1b1d; color:#8f909e; text-transform:uppercase; font-size:0.75rem;">
          <tr>
            <th class="px-4 py-3 w-8">#</th>
            <th class="px-4 py-3">Keyword</th>
            <th class="px-4 py-3 text-right">Count</th>
            <th class="px-4 py-3 text-right">Density</th>
            <th class="px-4 py-3 w-32">Bar</th>
          </tr>
        </thead>
        <tbody id="kd-tbody" style="color:#c5c5d5;"></tbody>
      </table>
    </div>
  </div>

  <script>
    const STOPWORDS = new Set(['a','an','the','and','or','but','in','on','at','to','for','of','with','by','from','as','is','was','are','were','be','been','being','have','has','had','do','does','did','will','would','could','should','may','might','shall','can','need','dare','ought','used','that','this','these','those','i','you','he','she','it','we','they','me','him','her','us','them','my','your','his','its','our','their','what','which','who','when','where','why','how','all','each','every','both','few','more','most','no','not','only','same','so','than','too','very','just','about','into','through','during','before','after','above','below','between','out','off','over','under','then','once','if','also','up','down','s','t','re','ve','ll','d','m'])

    const input = document.getElementById('kd-input')
    const stats = document.getElementById('kd-stats')
    const results = document.getElementById('kd-results')
    const tbody = document.getElementById('kd-tbody')

    input.addEventListener('input', analyze)

    function analyze() {
      const text = input.value.trim()
      if (!text) { stats.textContent = ''; results.classList.add('hidden'); return }

      const words = text.toLowerCase().match(/\b[a-z]{3,}\b/g) || []
      const filtered = words.filter(w => !STOPWORDS.has(w))
      const totalWords = words.length

      const freq = {}
      for (const w of filtered) freq[w] = (freq[w] || 0) + 1

      const sorted = Object.entries(freq).sort((a, b) => b[1] - a[1]).slice(0, 20)

      stats.textContent = `${totalWords.toLocaleString()} total words · ${filtered.length.toLocaleString()} meaningful words · ${Object.keys(freq).length} unique`

      if (!sorted.length) { results.classList.add('hidden'); return }

      const max = sorted[0][1]
      tbody.innerHTML = sorted.map(([word, count], i) => {
        const pct = (count / totalWords * 100).toFixed(2)
        const bar = Math.round(count / max * 100)
        return `<tr style="border-bottom:1px solid rgba(68,70,83,0.2);">
          <td class="px-4 py-2" style="color:#8f909e;">${i + 1}</td>
          <td class="px-4 py-2 font-medium" style="color:#e4e2e4;">${word}</td>
          <td class="px-4 py-2 text-right" style="color:#c5c5d5;">${count}</td>
          <td class="px-4 py-2 text-right" style="color:#c5c5d5;">${pct}%</td>
          <td class="px-4 py-2"><div style="height:0.5rem;border-radius:9999px;background:rgba(185,195,255,0.12);"><div style="height:0.5rem;border-radius:9999px;background:linear-gradient(90deg,#7189f6,#b9c3ff);width:${bar}%"></div></div></td>
        </tr>`
      }).join('')

      results.classList.remove('hidden')
    }
  </script>

  <section class="glass-card" style="margin-top:2.5rem; padding:1.5rem;">
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">How to use the Keyword Density Checker</h2>
    <p style="color:#c5c5d5; margin:0 0 1rem;">Paste your article, blog post, or web page content into the text area. The tool instantly shows you the top 20 most-used meaningful words along with their frequency count and density percentage.</p>
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">What is keyword density?</h2>
    <p style="color:#c5c5d5; margin:0 0 0.75rem;">Keyword density is the percentage of times a specific word appears relative to the total word count. A density of 1–3% for a target keyword is generally considered healthy for SEO. Higher densities may be flagged as keyword stuffing by search engines.</p>
    <p style="color:#c5c5d5; margin:0;">This tool filters out common English stopwords (the, and, is, etc.) so you see only meaningful content words.</p>
  </section>
</BaseLayout>
