---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'url-slug-generator')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['SEO']}>
  <nav style="margin-bottom:1.5rem;">
    <a href="/" style="color:#b9c3ff; text-decoration:none; font-size:0.875rem;">← All Tools</a>
  </nav>
  <div style="margin-bottom:2.5rem;">
    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-0.025em; color:#e4e2e4; margin:0 0 0.75rem;">{tool.title}</h1>
    <p style="color:#c5c5d5; font-size:1.05rem; margin:0; max-width:36rem; line-height:1.6;">{tool.description}</p>
  </div>

  <div class="glass-card space-y-4" style="padding:1.5rem;">
    <div>
      <label class="block text-sm font-medium mb-1" style="color:#c5c5d5;">Input Text</label>
      <input
        id="slug-input"
        type="text"
        placeholder="Best Running Shoes for Beginners 2025"
        class="w-full" style="border-radius:0.5rem; padding:0.5rem 0.75rem; font-size:1rem; width:100%;"
      />
    </div>

    <label class="flex items-center gap-2 text-sm cursor-pointer select-none" style="color:#c5c5d5;">
      <input id="slug-stopwords" type="checkbox" class="rounded" style="accent-color:#b9c3ff;" />
      Remove common stopwords (the, and, for, of…)
    </label>

    <div>
      <label class="block text-sm font-medium mb-1" style="color:#c5c5d5;">Generated Slug</label>
      <div class="flex gap-2">
        <input
          id="slug-output"
          type="text"
          readonly
          class="flex-1" style="border-radius:0.5rem; padding:0.5rem 0.75rem; font-size:1rem; font-family:monospace; color:#b9c3ff; background:#1b1b1d; border:1px solid rgba(68,70,83,0.4); width:100%;"
          placeholder="your-slug-will-appear-here"
        />
        <button id="slug-copy" class="btn-ghost" style="padding:0.5rem 1rem; border-radius:0.5rem; font-size:0.875rem; white-space:nowrap;">Copy</button>
      </div>
    </div>
  </div>

  <script>
    const STOPWORDS = new Set(['a','an','the','and','or','but','in','on','at','to','for','of','with','by','from','as','is','was','are','were','be','been','being','have','has','had','do','does','did','will','would','could','should','may','might','shall','can'])

    const inputEl = document.getElementById('slug-input')
    const outputEl = document.getElementById('slug-output')
    const stopwordsEl = document.getElementById('slug-stopwords')
    const copyBtn = document.getElementById('slug-copy')

    function slugify(text, removeStop) {
      let s = text.toLowerCase()
        .replace(/[àáâãäå]/g, 'a').replace(/[èéêë]/g, 'e')
        .replace(/[ìíîï]/g, 'i').replace(/[òóôõö]/g, 'o')
        .replace(/[ùúûü]/g, 'u').replace(/\u00f1/g, 'n').replace(/\u00e7/g, 'c')
        .replace(/[^a-z0-9\s-]/g, '')
        .trim().replace(/[\s_]+/g, '-').replace(/-+/g, '-')
      if (removeStop) {
        const parts = s.split('-').filter(w => !STOPWORDS.has(w))
        if (parts.length) s = parts.join('-')
      }
      return s || 'your-slug-here'
    }

    function update() {
      outputEl.value = inputEl.value.trim()
        ? slugify(inputEl.value, stopwordsEl.checked)
        : ''
    }

    inputEl.addEventListener('input', update)
    stopwordsEl.addEventListener('change', update)

    copyBtn.addEventListener('click', () => {
      if (!outputEl.value) return
      navigator.clipboard.writeText(outputEl.value).then(() => {
        copyBtn.textContent = 'Copied!'
        setTimeout(() => copyBtn.textContent = 'Copy', 1500)
      })
    })
  </script>

  <section class="glass-card" style="margin-top:2.5rem; padding:1.5rem;">
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">How to use the URL Slug Generator</h2>
    <p style="color:#c5c5d5; margin:0 0 1rem;">Type or paste your page title or any text into the input. The slug is generated instantly — lowercase, spaces replaced with hyphens, special characters removed. Toggle "Remove stopwords" to strip filler words like "the", "and", and "for" for a cleaner, shorter URL.</p>
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">What makes a good URL slug?</h2>
    <p style="color:#c5c5d5; margin:0 0 0.75rem;">A clean URL slug improves both SEO and readability. Best practices: use lowercase letters and hyphens only, include your primary keyword, keep it concise (3–5 meaningful words), and avoid dates unless they're essential for the content type.</p>
    <p style="color:#c5c5d5; margin:0;">Example: "Best Running Shoes for Beginners in 2025" → <code style="background:rgba(185,195,255,0.1); border-radius:0.25rem; padding:0.1rem 0.3rem; color:#b9c3ff;">best-running-shoes-beginners-2025</code></p>
  </section>
</BaseLayout>
