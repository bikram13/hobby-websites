---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'

const tool = tools.find(t => t.slug === 'url-slug-generator')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
---
<BaseLayout title={title} description={description}>
  <nav class="mb-6"><a href="/" class="text-blue-600 hover:text-blue-800 text-sm">← All Tools</a></nav>
  <h1 class="text-3xl font-bold text-gray-900 mb-3">{tool.title}</h1>
  <p class="text-gray-600 text-lg mb-6">{tool.description}</p>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Input Text</label>
      <input
        id="slug-input"
        type="text"
        placeholder="Best Running Shoes for Beginners 2025"
        class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-base text-gray-800 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
      />
    </div>

    <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer select-none">
      <input id="slug-stopwords" type="checkbox" class="rounded text-blue-600" />
      Remove common stopwords (the, and, for, of…)
    </label>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Generated Slug</label>
      <div class="flex gap-2">
        <input
          id="slug-output"
          type="text"
          readonly
          class="flex-1 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-base font-mono text-blue-700 focus:outline-none"
          placeholder="your-slug-will-appear-here"
        />
        <button id="slug-copy" class="rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm text-gray-700 hover:border-blue-400 hover:text-blue-600">Copy</button>
      </div>
    </div>
  </div>

  <script>
    const STOPWORDS = new Set(['a','an','the','and','or','but','in','on','at','to','for','of','with','by','from','as','is','was','are','were','be','been','being','have','has','had','do','does','did','will','would','could','should','may','might','shall','can'])

    const inputEl = document.getElementById('slug-input')
    const outputEl = document.getElementById('slug-output')
    const stopwordsEl = document.getElementById('slug-stopwords')
    const copyBtn = document.getElementById('slug-copy')

    function slugify(text, removeStop) {
      let s = text.toLowerCase()
        .replace(/[àáâãäå]/g, 'a').replace(/[èéêë]/g, 'e')
        .replace(/[ìíîï]/g, 'i').replace(/[òóôõö]/g, 'o')
        .replace(/[ùúûü]/g, 'u').replace(/\u00f1/g, 'n').replace(/\u00e7/g, 'c')
        .replace(/[^a-z0-9\s-]/g, '')
        .trim().replace(/[\s_]+/g, '-').replace(/-+/g, '-')
      if (removeStop) {
        const parts = s.split('-').filter(w => !STOPWORDS.has(w))
        if (parts.length) s = parts.join('-')
      }
      return s || 'your-slug-here'
    }

    function update() {
      outputEl.value = inputEl.value.trim()
        ? slugify(inputEl.value, stopwordsEl.checked)
        : ''
    }

    inputEl.addEventListener('input', update)
    stopwordsEl.addEventListener('change', update)

    copyBtn.addEventListener('click', () => {
      if (!outputEl.value) return
      navigator.clipboard.writeText(outputEl.value).then(() => {
        copyBtn.textContent = 'Copied!'
        setTimeout(() => copyBtn.textContent = 'Copy', 1500)
      })
    })
  </script>

  <section class="mt-12 border-t border-gray-200 pt-8 text-gray-600 text-sm leading-relaxed space-y-4">
    <h2 class="text-xl font-semibold text-gray-800">How to use the URL Slug Generator</h2>
    <p>Type or paste your page title or any text into the input. The slug is generated instantly — lowercase, spaces replaced with hyphens, special characters removed. Toggle "Remove stopwords" to strip filler words like "the", "and", and "for" for a cleaner, shorter URL.</p>
    <h2 class="text-xl font-semibold text-gray-800">What makes a good URL slug?</h2>
    <p>A clean URL slug improves both SEO and readability. Best practices: use lowercase letters and hyphens only, include your primary keyword, keep it concise (3–5 meaningful words), and avoid dates unless they're essential for the content type.</p>
    <p>Example: "Best Running Shoes for Beginners in 2025" → <code class="bg-gray-100 px-1 rounded">best-running-shoes-beginners-2025</code></p>
  </section>
</BaseLayout>
