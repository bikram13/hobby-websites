---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'open-graph-generator')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['SEO']}>
  <nav style="margin-bottom:1.5rem;">
    <a href="/" style="color:#b9c3ff; text-decoration:none; font-size:0.875rem;">← All Tools</a>
  </nav>
  <div style="margin-bottom:2.5rem;">
    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-0.025em; color:#e4e2e4; margin:0 0 0.75rem;">{tool.title}</h1>
    <p style="color:#c5c5d5; font-size:1.05rem; margin:0; max-width:36rem; line-height:1.6;">{tool.description}</p>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <!-- Inputs -->
    <div class="glass-card space-y-4" style="padding:1.5rem;">
      <div>
        <label class="block text-sm font-medium mb-1" style="color:#c5c5d5;">OG Title <span id="og-title-count" class="font-normal" style="color:#8f909e;">0 / 60</span></label>
        <input id="og-title" type="text" maxlength="100" placeholder="My Awesome Page Title"
          class="w-full" style="border-radius:0.5rem; padding:0.5rem 0.75rem; font-size:0.875rem; width:100%;" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1" style="color:#c5c5d5;">OG Description <span id="og-desc-count" class="font-normal" style="color:#8f909e;">0 / 200</span></label>
        <textarea id="og-desc" rows="3" maxlength="300" placeholder="A short description of this page for social sharing."
          class="w-full" style="border-radius:0.5rem; padding:0.5rem 0.75rem; font-size:0.875rem; resize:none; width:100%;"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1" style="color:#c5c5d5;">Page URL</label>
        <input id="og-url" type="url" placeholder="https://yoursite.com/page/"
          class="w-full" style="border-radius:0.5rem; padding:0.5rem 0.75rem; font-size:0.875rem; width:100%;" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1" style="color:#c5c5d5;">Image URL <span class="font-normal" style="color:#8f909e;">(1200×630 recommended)</span></label>
        <input id="og-image" type="url" placeholder="https://yoursite.com/og-image.png"
          class="w-full" style="border-radius:0.5rem; padding:0.5rem 0.75rem; font-size:0.875rem; width:100%;" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1" style="color:#c5c5d5;">Site Name</label>
        <input id="og-site" type="text" placeholder="My Website"
          class="w-full" style="border-radius:0.5rem; padding:0.5rem 0.75rem; font-size:0.875rem; width:100%;" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1" style="color:#c5c5d5;">Twitter Card Type</label>
        <select id="og-twitter-card"
          class="w-full" style="border-radius:0.5rem; padding:0.5rem 0.75rem; font-size:0.875rem; width:100%;">
          <option value="summary_large_image">Summary with Large Image</option>
          <option value="summary">Summary</option>
        </select>
      </div>
    </div>

    <!-- Previews -->
    <div class="space-y-4">
      <!-- Facebook/OG preview -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide mb-2" style="color:#8f909e;">Facebook / LinkedIn Preview</p>
        <div class="rounded-lg overflow-hidden max-w-md" style="border:1px solid rgba(68,70,83,0.4); font-family:Helvetica,Arial,sans-serif;">
          <div id="og-preview-img" class="h-48 flex items-center justify-center text-sm" style="background:#1b1b1d; color:#8f909e;">No image URL provided</div>
          <div style="background:#1e1e22; padding:0.75rem; border-top:1px solid rgba(68,70,83,0.4);">
            <div id="og-preview-site" style="font-size:0.6875rem; text-transform:uppercase; color:#8f909e; margin-bottom:0.125rem;">yoursite.com</div>
            <div id="og-preview-title" style="font-size:0.875rem; font-weight:600; color:#e4e2e4; line-height:1.3;">Page title</div>
            <div id="og-preview-desc" style="font-size:0.8125rem; color:#8f909e; line-height:1.4; margin-top:0.125rem; display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">Page description</div>
          </div>
        </div>
      </div>

      <!-- Twitter/X preview -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide mb-2" style="color:#8f909e;">Twitter / X Preview</p>
        <div class="rounded-2xl overflow-hidden max-w-md" style="border:1px solid rgba(68,70,83,0.4); font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
          <div id="tw-preview-img" class="h-40 flex items-center justify-center text-sm" style="background:#1b1b1d; color:#8f909e;">No image URL provided</div>
          <div style="padding:0.75rem; background:#1e1e22;">
            <div id="tw-preview-title" class="text-sm font-bold" style="color:#e4e2e4;">Page title</div>
            <div id="tw-preview-desc" class="text-sm leading-snug mt-0.5 line-clamp-2" style="color:#8f909e;">Page description</div>
            <div id="tw-preview-url" class="text-xs mt-1" style="color:#8f909e;">yoursite.com</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Output -->
  <div class="mt-6">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wide" style="color:#8f909e;">Generated Tags</h2>
      <button id="og-copy" class="rounded-md px-3 py-1 text-xs" style="background:rgba(53,52,55,0.8); color:#c5c5d5; border:1px solid rgba(68,70,83,0.4); cursor:pointer;">Copy</button>
    </div>
    <pre id="og-output" class="rounded-lg text-xs p-4 overflow-x-auto whitespace-pre-wrap min-h-[60px]" style="background:#0d0d0f; color:#4edea3; border:1px solid rgba(68,70,83,0.4);"></pre>
  </div>

  <script>
    const $ = id => document.getElementById(id)
    const fields = {
      title: $('og-title'), desc: $('og-desc'), url: $('og-url'),
      image: $('og-image'), site: $('og-site'), twitterCard: $('og-twitter-card')
    }

    function getDomain(url) {
      try { return new URL(url).hostname } catch { return url.replace(/^https?:\/\//, '').split('/')[0] || 'yoursite.com' }
    }

    function update() {
      const t = fields.title.value, d = fields.desc.value, u = fields.url.value,
            img = fields.image.value, site = fields.site.value, tc = fields.twitterCard.value

      $('og-title-count').textContent = `${t.length} / 60`
      $('og-title-count').className = `font-normal ${t.length > 60 ? 'text-red-500' : 'text-gray-500'}`
      $('og-desc-count').textContent = `${d.length} / 200`
      $('og-desc-count').className = `font-normal ${d.length > 200 ? 'text-red-500' : 'text-gray-500'}`

      // Update previews
      $('og-preview-title').textContent = t || 'Page title'
      $('og-preview-desc').textContent = d || 'Page description'
      $('og-preview-site').textContent = getDomain(u)
      $('tw-preview-title').textContent = t || 'Page title'
      $('tw-preview-desc').textContent = d || 'Page description'
      $('tw-preview-url').textContent = getDomain(u)

      if (img) {
        const errHtml = `<div class="flex flex-col items-center gap-2"><span class="text-sm text-red-500">Image failed to load</span><button onclick="document.getElementById('og-image').value='';document.getElementById('og-image').dispatchEvent(new Event('input',{bubbles:true}))" class="text-xs bg-red-100 hover:bg-red-200 text-red-700 rounded px-2 py-1 transition-colors">Clear image URL</button></div>`
        $('og-preview-img').innerHTML = `<img src="${img}" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML='${errHtml.replace(/'/g,"\\'")}'" />`
        $('tw-preview-img').innerHTML = `<img src="${img}" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML='${errHtml.replace(/'/g,"\\'")}'" />`
      } else {
        $('og-preview-img').textContent = 'No image URL provided'
        $('tw-preview-img').textContent = 'No image URL provided'
      }

      const esc = s => s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      const lines = []
      if (t) { lines.push(`<meta property="og:title" content="${esc(t)}">`) }
      if (d) { lines.push(`<meta property="og:description" content="${esc(d)}">`) }
      if (u) { lines.push(`<meta property="og:url" content="${esc(u)}">`) }
      if (img) { lines.push(`<meta property="og:image" content="${esc(img)}">`) }
      if (site) { lines.push(`<meta property="og:site_name" content="${esc(site)}">`) }
      lines.push(`<meta property="og:type" content="website">`)
      lines.push(``)
      lines.push(`<meta name="twitter:card" content="${tc}">`)
      if (t) lines.push(`<meta name="twitter:title" content="${esc(t)}">`)
      if (d) lines.push(`<meta name="twitter:description" content="${esc(d)}">`)
      if (img) lines.push(`<meta name="twitter:image" content="${esc(img)}">`)

      $('og-output').textContent = lines.join('\n')
    }

    Object.values(fields).forEach(el => el.addEventListener('input', update))
    $('og-copy').addEventListener('click', () => {
      navigator.clipboard.writeText($('og-output').textContent).then(() => {
        $('og-copy').textContent = 'Copied!'
        setTimeout(() => $('og-copy').textContent = 'Copy', 1500)
      })
    })
    update()
  </script>

  <section class="glass-card" style="margin-top:2.5rem; padding:1.5rem;">
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">How to use the Open Graph Generator</h2>
    <p style="color:#c5c5d5; margin:0 0 1rem;">Fill in the fields above. The Facebook/LinkedIn and Twitter/X previews update instantly so you can see exactly how your link will appear when shared. Copy the generated tags and paste them into the <code style="background:rgba(185,195,255,0.1); border-radius:0.25rem; padding:0.1rem 0.3rem; color:#b9c3ff;">&lt;head&gt;</code> of your page.</p>
    <h2 style="color:#e4e2e4; font-size:1.125rem; font-weight:600; margin:0 0 0.75rem;">What are Open Graph tags?</h2>
    <p style="color:#c5c5d5; margin:0;">Open Graph (OG) tags are meta tags that control how a webpage appears when shared on social media. Without them, platforms guess the title, description, and image — often with poor results. OG tags let you define exactly what users see, improving click-through rates.</p>
  </section>
</BaseLayout>
