---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { tools } from '../../data/tools'
import { toolJsonLd, affiliates } from '../../data/jsonld'

const tool = tools.find(t => t.slug === 'open-graph-generator')!
const title = `${tool.title} — Free Online Tool`
const description = tool.description
const jsonLd = toolJsonLd(tool.slug, tool.title, tool.description, tool.path)
---
<BaseLayout title={title} description={description} jsonLd={jsonLd} affiliateLinks={affiliates['SEO']}>
  <nav class="mb-6"><a href="/" class="text-blue-600 hover:text-blue-800 text-sm">← All Tools</a></nav>
  <h1 class="text-3xl font-bold text-gray-900 mb-3">{tool.title}</h1>
  <p class="text-gray-600 text-lg mb-6">{tool.description}</p>

  <div class="grid gap-6 lg:grid-cols-2">
    <!-- Inputs -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">OG Title <span id="og-title-count" class="font-normal text-gray-500">0 / 60</span></label>
        <input id="og-title" type="text" maxlength="100" placeholder="My Awesome Page Title"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-800 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">OG Description <span id="og-desc-count" class="font-normal text-gray-500">0 / 200</span></label>
        <textarea id="og-desc" rows="3" maxlength="300" placeholder="A short description of this page for social sharing."
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-800 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200 resize-none"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Page URL</label>
        <input id="og-url" type="url" placeholder="https://yoursite.com/page/"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-800 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Image URL <span class="font-normal text-gray-500">(1200×630 recommended)</span></label>
        <input id="og-image" type="url" placeholder="https://yoursite.com/og-image.png"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-800 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Site Name</label>
        <input id="og-site" type="text" placeholder="My Website"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-800 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Twitter Card Type</label>
        <select id="og-twitter-card"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-800 focus:border-blue-500 focus:outline-none">
          <option value="summary_large_image">Summary with Large Image</option>
          <option value="summary">Summary</option>
        </select>
      </div>
    </div>

    <!-- Previews -->
    <div class="space-y-4">
      <!-- Facebook/OG preview -->
      <div>
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Facebook / LinkedIn Preview</p>
        <div class="rounded-lg border border-gray-200 overflow-hidden shadow-sm max-w-md" style="font-family:Helvetica,Arial,sans-serif">
          <div id="og-preview-img" class="bg-gray-100 h-48 flex items-center justify-center text-gray-600 text-sm">No image URL provided</div>
          <div class="bg-[#f0f2f5] px-3 py-2 border-t border-gray-200">
            <div id="og-preview-site" class="text-[11px] uppercase text-gray-500 mb-0.5">yoursite.com</div>
            <div id="og-preview-title" class="text-[14px] font-semibold text-gray-900 leading-tight">Page title</div>
            <div id="og-preview-desc" class="text-[13px] text-gray-500 leading-snug mt-0.5 line-clamp-2">Page description</div>
          </div>
        </div>
      </div>

      <!-- Twitter/X preview -->
      <div>
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Twitter / X Preview</p>
        <div class="rounded-2xl border border-gray-200 overflow-hidden shadow-sm max-w-md" style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif">
          <div id="tw-preview-img" class="bg-gray-100 h-40 flex items-center justify-center text-gray-600 text-sm">No image URL provided</div>
          <div class="px-3 py-2">
            <div id="tw-preview-title" class="text-sm font-bold text-gray-900">Page title</div>
            <div id="tw-preview-desc" class="text-sm text-gray-500 leading-snug mt-0.5 line-clamp-2">Page description</div>
            <div id="tw-preview-url" class="text-xs text-gray-500 mt-1">yoursite.com</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Output -->
  <div class="mt-6">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold text-gray-600 uppercase tracking-wide">Generated Tags</h2>
      <button id="og-copy" class="rounded-md border border-gray-300 bg-white px-3 py-1 text-xs text-gray-600 hover:border-blue-400 hover:text-blue-600">Copy</button>
    </div>
    <pre id="og-output" class="rounded-lg bg-gray-900 text-green-400 text-xs p-4 overflow-x-auto whitespace-pre-wrap min-h-[60px]"></pre>
  </div>

  <script>
    const $ = id => document.getElementById(id)
    const fields = {
      title: $('og-title'), desc: $('og-desc'), url: $('og-url'),
      image: $('og-image'), site: $('og-site'), twitterCard: $('og-twitter-card')
    }

    function getDomain(url) {
      try { return new URL(url).hostname } catch { return url.replace(/^https?:\/\//, '').split('/')[0] || 'yoursite.com' }
    }

    function update() {
      const t = fields.title.value, d = fields.desc.value, u = fields.url.value,
            img = fields.image.value, site = fields.site.value, tc = fields.twitterCard.value

      $('og-title-count').textContent = `${t.length} / 60`
      $('og-title-count').className = `font-normal ${t.length > 60 ? 'text-red-500' : 'text-gray-500'}`
      $('og-desc-count').textContent = `${d.length} / 200`
      $('og-desc-count').className = `font-normal ${d.length > 200 ? 'text-red-500' : 'text-gray-500'}`

      // Update previews
      $('og-preview-title').textContent = t || 'Page title'
      $('og-preview-desc').textContent = d || 'Page description'
      $('og-preview-site').textContent = getDomain(u)
      $('tw-preview-title').textContent = t || 'Page title'
      $('tw-preview-desc').textContent = d || 'Page description'
      $('tw-preview-url').textContent = getDomain(u)

      if (img) {
        const errHtml = `<div class="flex flex-col items-center gap-2"><span class="text-sm text-red-500">Image failed to load</span><button onclick="document.getElementById('og-image').value='';document.getElementById('og-image').dispatchEvent(new Event('input',{bubbles:true}))" class="text-xs bg-red-100 hover:bg-red-200 text-red-700 rounded px-2 py-1 transition-colors">Clear image URL</button></div>`
        $('og-preview-img').innerHTML = `<img src="${img}" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML='${errHtml.replace(/'/g,"\\'")}'" />`
        $('tw-preview-img').innerHTML = `<img src="${img}" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML='${errHtml.replace(/'/g,"\\'")}'" />`
      } else {
        $('og-preview-img').textContent = 'No image URL provided'
        $('tw-preview-img').textContent = 'No image URL provided'
      }

      const esc = s => s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      const lines = []
      if (t) { lines.push(`<meta property="og:title" content="${esc(t)}">`) }
      if (d) { lines.push(`<meta property="og:description" content="${esc(d)}">`) }
      if (u) { lines.push(`<meta property="og:url" content="${esc(u)}">`) }
      if (img) { lines.push(`<meta property="og:image" content="${esc(img)}">`) }
      if (site) { lines.push(`<meta property="og:site_name" content="${esc(site)}">`) }
      lines.push(`<meta property="og:type" content="website">`)
      lines.push(``)
      lines.push(`<meta name="twitter:card" content="${tc}">`)
      if (t) lines.push(`<meta name="twitter:title" content="${esc(t)}">`)
      if (d) lines.push(`<meta name="twitter:description" content="${esc(d)}">`)
      if (img) lines.push(`<meta name="twitter:image" content="${esc(img)}">`)

      $('og-output').textContent = lines.join('\n')
    }

    Object.values(fields).forEach(el => el.addEventListener('input', update))
    $('og-copy').addEventListener('click', () => {
      navigator.clipboard.writeText($('og-output').textContent).then(() => {
        $('og-copy').textContent = 'Copied!'
        setTimeout(() => $('og-copy').textContent = 'Copy', 1500)
      })
    })
    update()
  </script>

  <section class="mt-12 border-t border-gray-200 pt-8 text-gray-600 text-sm leading-relaxed space-y-4">
    <h2 class="text-xl font-semibold text-gray-800">How to use the Open Graph Generator</h2>
    <p>Fill in the fields above. The Facebook/LinkedIn and Twitter/X previews update instantly so you can see exactly how your link will appear when shared. Copy the generated tags and paste them into the <code class="bg-gray-100 px-1 rounded">&lt;head&gt;</code> of your page.</p>
    <h2 class="text-xl font-semibold text-gray-800">What are Open Graph tags?</h2>
    <p>Open Graph (OG) tags are meta tags that control how a webpage appears when shared on social media. Without them, platforms guess the title, description, and image — often with poor results. OG tags let you define exactly what users see, improving click-through rates.</p>
  </section>
</BaseLayout>
