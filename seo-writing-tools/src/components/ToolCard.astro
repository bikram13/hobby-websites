---
import type { Tool } from '../data/tools'

interface Props {
  tool: Tool
}

const { tool } = Astro.props

const categoryColor: Record<string, string> = {
  Writing: '#b9c3ff',
  SEO:     '#4edea3',
}
const catColor = categoryColor[tool.category] ?? '#b9c3ff'
---
<a
  href={tool.path}
  data-category={tool.category}
  class="tool-card"
  style={`
    display: block;
    padding: 1.25rem;
    border-radius: 0.75rem;
    background: rgba(53, 52, 55, 0.45);
    border: 1px solid rgba(68, 70, 83, 0.3);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  `}
  onmouseover="this.style.borderColor='rgba(113,137,246,0.5)';this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 30px rgba(113,137,246,0.12)'"
  onmouseout="this.style.borderColor='rgba(68,70,83,0.3)';this.style.transform='';this.style.boxShadow=''"
>
  <span style={`display:inline-block; margin-bottom:0.5rem; font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:${catColor}; background:${catColor}18; padding:0.2rem 0.6rem; border-radius:9999px; border:1px solid ${catColor}30;`}>
    {tool.category}
  </span>
  <h2 style="font-size:0.95rem; font-weight:600; color:#e4e2e4; margin:0 0 0.25rem;">{tool.title}</h2>
  <p style="font-size:0.85rem; color:#c5c5d5; line-height:1.55; margin:0;">{tool.description}</p>
</a>
