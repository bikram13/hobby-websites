---
import '../styles/global.css'

interface Props {
  title: string
  description: string
  jsonLd?: string
  affiliateLinks?: { name: string; url: string; desc: string }[]
}

const { title, description, jsonLd } = Astro.props
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>✍️</text></svg>" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SEO & Writing Tools" />
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
  </head>
  <body style="background:#131315; color:#e4e2e4; font-family:'Inter',system-ui,sans-serif; margin:0; min-height:100vh;">

    <!-- Header -->
    <header style="position:fixed; top:0; width:100%; z-index:50; background:rgba(30,30,32,0.6); backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px); border-bottom:1px solid rgba(255,255,255,0.08);">
      <nav style="display:flex; align-items:center; justify-content:space-between; padding:1rem 2rem; max-width:1400px; margin:0 auto;">
        <a href="/" style="font-size:1.1rem; font-weight:700; background:linear-gradient(to right,#818cf8,#c084fc); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; text-decoration:none;">
          SEO &amp; Writing Tools
        </a>
        <div class="header-links" style="display:flex; align-items:center; gap:2rem;">
          <a href="/#writing" style="color:#9ca3af; font-size:0.875rem; text-decoration:none; transition:color 0.2s;" onmouseover="this.style.color='#e4e2e4'" onmouseout="this.style.color='#9ca3af'">Writing</a>
          <a href="/#seo" style="color:#9ca3af; font-size:0.875rem; text-decoration:none; transition:color 0.2s;" onmouseover="this.style.color='#e4e2e4'" onmouseout="this.style.color='#9ca3af'">SEO</a>
          <a href="https://everyday-tools.pages.dev" target="_blank" rel="noopener" style="color:#9ca3af; font-size:0.875rem; text-decoration:none; transition:color 0.2s;" onmouseover="this.style.color='#e4e2e4'" onmouseout="this.style.color='#9ca3af'">Everyday Tools ↗</a>
        </div>
        <button id="hamburger-btn" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu"
          style="display:none; flex-direction:column; justify-content:center; align-items:center; width:2rem; height:2rem; gap:5px; background:none; border:none; cursor:pointer; padding:0;">
          <span class="ham-line" style="display:block; width:1.5rem; height:2px; background:#d1d5db; transition:all 0.3s;"></span>
          <span class="ham-line" style="display:block; width:1.5rem; height:2px; background:#d1d5db; transition:all 0.3s;"></span>
          <span class="ham-line" style="display:block; width:1.5rem; height:2px; background:#d1d5db; transition:all 0.3s;"></span>
        </button>
      </nav>
      <!-- Mobile menu -->
      <div id="mobile-menu" style="display:none; flex-direction:column; padding:1rem 2rem 1.5rem; gap:1rem; border-top:1px solid rgba(255,255,255,0.08); background:rgba(19,19,21,0.95);">
        <a href="/#writing" style="color:#9ca3af; font-size:0.875rem; text-decoration:none; padding:0.5rem 0; border-bottom:1px solid rgba(255,255,255,0.06);">Writing</a>
        <a href="/#seo" style="color:#9ca3af; font-size:0.875rem; text-decoration:none; padding:0.5rem 0; border-bottom:1px solid rgba(255,255,255,0.06);">SEO</a>
        <a href="https://everyday-tools.pages.dev" target="_blank" rel="noopener" style="color:#9ca3af; font-size:0.875rem; text-decoration:none; padding:0.5rem 0;">Everyday Tools ↗</a>
      </div>
    </header>

    <!-- Page gradient glow -->
    <div style="position:fixed; top:-10%; right:-5%; width:500px; height:500px; background:rgba(113,137,246,0.07); border-radius:50%; filter:blur(120px); pointer-events:none; z-index:0;"></div>
    <div style="position:fixed; bottom:5%; left:10%; width:400px; height:400px; background:rgba(220,184,255,0.05); border-radius:50%; filter:blur(100px); pointer-events:none; z-index:0;"></div>

    <!-- Main content -->
    <main style="max-width:1100px; margin:0 auto; padding:7rem 1.5rem 4rem; position:relative; z-index:1;">
      <slot />
    </main>

    <!-- Footer -->
    <footer style="border-top:1px solid rgba(255,255,255,0.06); margin-top:4rem; padding:3rem 1.5rem; background:rgba(14,14,16,0.4); backdrop-filter:blur(10px);">
      <div style="max-width:1100px; margin:0 auto; display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:1.5rem;">
        <div style="font-size:0.875rem; color:#6b7280;">
          © 2026 SEO &amp; Writing Tools. Free. No signup. No tracking.
        </div>
        <div style="display:flex; flex-wrap:wrap; gap:1.5rem;">
          <a href="https://everyday-tools.pages.dev" target="_blank" rel="noopener" style="font-size:0.875rem; color:#6b7280; text-decoration:none; transition:color 0.2s;" onmouseover="this.style.color='#4edea3'" onmouseout="this.style.color='#6b7280'">Everyday Tools</a>
        </div>
        <div style="display:flex; align-items:center; gap:0.5rem; color:#4edea3;">
          <span class="material-symbols-outlined" style="font-size:1.1rem;">verified_user</span>
          <span style="font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em;">Secure &amp; Private</span>
        </div>
      </div>
    </footer>

    <style>
      @media (max-width: 768px) {
        .header-links { display: none !important; }
        #hamburger-btn { display: flex !important; }
      }
    </style>

    <script is:inline>
      (function () {
        var btn  = document.getElementById('hamburger-btn');
        var menu = document.getElementById('mobile-menu');
        if (!btn || !menu) return;
        btn.addEventListener('click', function () {
          var open = menu.style.display === 'flex';
          menu.style.display = open ? 'none' : 'flex';
          btn.setAttribute('aria-expanded', open ? 'false' : 'true');
        });
        menu.querySelectorAll('a').forEach(function (a) {
          a.addEventListener('click', function () {
            menu.style.display = 'none';
            btn.setAttribute('aria-expanded', 'false');
          });
        });
      })();
    </script>
  </body>
</html>
